<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <record id="module_category_lc_letter" model="ir.module.category">
            <field name="name">Foreign Payment Term Process</field>
            <field name="description">Access rights for foreign payment term management (LC, CAD, TT)</field>
            <field name="sequence">20</field>
        </record>

        <record id="group_lc_payment_submit" model="res.groups">
            <field name="name">Payment Line: Submit</field>
            <field name="category_id" ref="module_category_lc_letter"/>
        </record>

        <record id="group_lc_payment_verify" model="res.groups">
            <field name="name">Payment Line: Verify</field>
            <field name="category_id" ref="module_category_lc_letter"/>
        </record>

        <record id="group_lc_payment_authorize" model="res.groups">
            <field name="name">Payment Line: Authorize</field>
            <field name="category_id" ref="module_category_lc_letter"/>
        </record>

        <record id="group_lc_payment_approve" model="res.groups">
            <field name="name">Payment Line: Approve</field>
            <field name="category_id" ref="module_category_lc_letter"/>
        </record>

        <record id="group_lc_payment_reject" model="res.groups">
            <field name="name">Payment Line: Reject</field>
            <field name="category_id" ref="module_category_lc_letter"/>
        </record>

        <record id="group_lc_payment_cancel" model="res.groups">
            <field name="name">Payment Line: Cancel</field>
            <field name="category_id" ref="module_category_lc_letter"/>
        </record>

        <record id="group_lc_payment_reset_draft" model="res.groups">
            <field name="name">Payment Line: Reset to Draft</field>
            <field name="category_id" ref="module_category_lc_letter"/>
        </record>

        <record id="lc_letter_multi_company_rule" model="ir.rule">
            <field name="name">Foreign Payment Term Multi-Company</field>
            <field name="model_id" ref="lc_letter.model_lc_letter"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>
    </data>
</odoo>
