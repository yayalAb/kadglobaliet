<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_lc_letter_kanban" model="ir.ui.view">
        <field name="name">lc.letter.kanban</field>
        <field name="model">lc.letter</field>
        <field name="arch" type="xml">
            <kanban default_group_by="stage_id"
                class="o_kanban_small_column"
                quick_create="false">
                <field name="stage_id"/>
                <field name="id"/>
                <field name="name"/>
                <field name="payment_instrument"/>
                <field name="payment_subtype"/>
                <field name="issuing_bank_id"/>
                <field name="applicant_id"/>
                <field name="beneficiary_id"/>
                <field name="amount"/>
                <field name="currency_id"/>
                <field name="issue_date"/>
                <field name="expiry_date"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong><field name="name"/></strong>
                                </div>
                                <span class="badge rounded-pill text-bg-secondary">
                                    <field name="payment_instrument"/>
                                </span>
                            </div>
                            <div class="o_kanban_record_body">
                                <field name="payment_subtype"/>
                                <field name="amount" widget="monetary"
                                    options="{'currency_field': 'currency_id'}"/>
                                <div t-if="record.issuing_bank_id.value">
                                    <i class="fa fa-university me-1" title="Bank"/> <field name="issuing_bank_id"/>
                                </div>
                                <div class="text-muted small mt-1">
                                    <field name="applicant_id"/> → <field name="beneficiary_id"/>
                                </div>
                                <div class="text-muted small" t-if="record.expiry_date.raw_value">
                                    <i class="fa fa-calendar me-1" title="Expiry Date"/> Expires: <field name="expiry_date"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_lc_letter_tree" model="ir.ui.view">
        <field name="name">lc.letter.tree</field>
        <field name="model">lc.letter</field>
        <field name="arch" type="xml">
            <list string="Foreign Payment Terms">
                <field name="name"/>
                <field name="payment_instrument"/>
                <field name="payment_subtype"/>
                <field name="stage_id"/>
                <field name="issuing_bank_id"/>
                <field name="applicant_id"/>
                <field name="beneficiary_id"/>
                <field name="amount"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="issue_date"/>
                <field name="expiry_date"/>
            </list>
        </field>
    </record>

    <record id="view_lc_letter_search" model="ir.ui.view">
        <field name="name">lc.letter.search</field>
        <field name="model">lc.letter</field>
        <field name="arch" type="xml">
            <search string="Foreign Payment Terms">
                <field name="name"/>
                <field name="applicant_id"/>
                <field name="beneficiary_id"/>
                <field name="issuing_bank_id"/>
                <filter name="filter_lc" string="Letter of Credit"
                    domain="[('payment_instrument', '=', 'lc')]"/>
                <filter name="filter_cad" string="Cash Against Documents"
                    domain="[('payment_instrument', '=', 'cad')]"/>
                <filter name="filter_tt" string="Advance Payment (TT)"
                    domain="[('payment_instrument', '=', 'tt')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_instrument" string="Payment Instrument"
                        context="{'group_by': 'payment_instrument'}"/>
                    <filter name="group_subtype" string="Payment Type"
                        context="{'group_by': 'payment_subtype'}"/>
                    <filter name="group_stage" string="Stage"
                        context="{'group_by': 'stage_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_lc_letter_form" model="ir.ui.view">
        <field name="name">lc.letter.form</field>
        <field name="model">lc.letter</field>
        <field name="arch" type="xml">
            <form string="Foreign Payment Term">
                <header>
                    <field name="stage_id" widget="statusbar"
                        options="{'clickable': '1', 'fold_field': 'fold'}"/>
                    <button name="action_payment_request" type="object" string="Payment Request" class="btn-primary"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_purchase_orders" type="object"
                            class="oe_stat_button" icon="fa-shopping-cart"
                            invisible="purchase_order_count == 0">
                            <field name="purchase_order_count" widget="statinfo" string="Purchase Orders"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="payment_reference_label" invisible="1"/>
                            <field name="name"
                                   string="LC/Reference No."
                                   placeholder="Leave empty to auto-generate"/>
                            <field name="payment_instrument"/>
                            <field name="payment_subtype"/>
                            <field name="lc_type" invisible="payment_instrument != 'lc'"/>
                            <field name="issuing_bank_id" invisible="payment_instrument == 'tt'"/>
                            <field name="advising_bank_id" invisible="payment_instrument != 'lc'"/>
                            <field name="applicant_id"/>
                            <field name="beneficiary_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="amount"/>
                            <field name="currency_id"/>
                            <field name="issue_date"/>
                            <field name="expiry_date" required="payment_instrument == 'lc'"/>
                            <field name="latest_shipment_date"
                                invisible="payment_instrument == 'tt'"/>
                            <field name="description" colspan="2"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Payment Lines">
                            <field name="payment_line_ids">
                                <list editable="bottom" create="0" delete="1" open="form">
                                    <field name="partner_id" readonly="state != 'draft'"/>
                                    <field name="product_id" readonly="state != 'draft'"/>
                                    <field name="amount" readonly="state != 'draft'"/>
                                    <field name="state" widget="badge"
                                        decoration-info="state == 'verified'"
                                        decoration-warning="state == 'authorized'"
                                        decoration-success="state == 'approved'"
                                        decoration-danger="state in ('rejected', 'cancelled')"/>
                                    <button name="action_submit" string="Submit" type="object"
                                        class="btn-link" groups="lc_letter.group_lc_payment_submit" invisible="state != 'draft'"/>
                                    <button name="action_verify" string="Verify" type="object"
                                        class="btn-link" groups="lc_letter.group_lc_payment_verify" invisible="state != 'submitted'"/>
                                    <button name="action_authorize" string="Authorize" type="object"
                                        class="btn-link" groups="lc_letter.group_lc_payment_authorize" invisible="state != 'verified'"/>
                                    <button name="action_approve" string="Approve" type="object"
                                        class="btn-link" groups="lc_letter.group_lc_payment_approve" invisible="state != 'authorized'"/>
                                    <button name="action_reject" string="Reject" type="object"
                                        class="btn-link text-danger" groups="lc_letter.group_lc_payment_reject" invisible="state not in ('submitted', 'verified', 'authorized')"/>
                                    <button name="action_cancel" string="Cancel" type="object"
                                        class="btn-link" groups="lc_letter.group_lc_payment_cancel" invisible="state not in ('submitted', 'verified', 'authorized')"/>
                                    <button name="action_reset_draft" string="Reset" type="object"
                                        class="btn-link" groups="lc_letter.group_lc_payment_reset_draft" invisible="state == 'approved'"/>
                                </list>
                                <form>
                                    <group>
                                        <group>
                                            <field name="lc_letter_id" invisible="1"/>
                                            <field name="partner_id" readonly="state != 'draft'"/>
                                            <field name="product_id" readonly="state != 'draft'"/>
                                            <field name="amount" readonly="state != 'draft'"/>
                                            <field name="currency_id" invisible="1"/>
                                            <field name="state"/>
                                        </group>
                                    </group>
                                </form>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="notes" placeholder="Internal notes..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_lc_letter" model="ir.actions.act_window">
        <field name="name">Foreign Payment Term Process</field>
        <field name="res_model">lc.letter</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="view_lc_letter_search"/>
        <field name="context">{'default_payment_instrument': 'lc'}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new foreign payment term
            </p>
            <p>
                Manage Letter of Credit, Cash Against Documents, and Advance Payment (TT) for import purchases.
            </p>
        </field>
    </record>

    <menuitem id="menu_lc_letter_root"
        name="Foreign Payment Term Process"
        parent="purchase.menu_purchase_root"
        action="action_lc_letter"
        sequence="50"/>
</odoo>
