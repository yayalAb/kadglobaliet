<odoo>
    <record id="stock_picking_view_inherited_form" model="ir.ui.view">
        <field name="name">stock.picking.view.inherited.form</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form" />
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="inside">
                <field name="picking_type_code" invisible="1" />
            </xpath>
            <xpath expr="//field[@name='location_id']" position="after">
                <field name="store_request_id" options="{'no_create': True}"
                    invisible="picking_type_id.code != 'outgoing'" readonly="1" />
            </xpath>
            <xpath expr="//field[@name='origin']" position="after">
                <field name="approved_by" readonly='1' />
            </xpath>
            <xpath expr="//field[@name='backorder_id']" position="after">
                <field name="driver_name"/>
                <field name="driver_phone"/>
            </xpath>
            <xpath expr="//field[@name='move_ids_without_package']//field[@name='quantity']"
                position="after">
                <field name="company_currency_id" column_invisible="True" />
                <field name="line_unit_price" optional="hide" readonly="1" />
                <field name="line_subtotal" optional="hide" readonly="1" />
            </xpath>
        </field>
    </record>

    <record id="stock.stock_picking_type_action" model="ir.actions.act_window">
        <field name="context">{'search_default_groupby_code': 1}</field>
    </record>
</odoo>