<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_move_form_fs_mrc_payment" model="ir.ui.view">
        <field name="name">account.move.form.fs.mrc.payment</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='refresh_invoice_currency_rate']" position="replace"/>
            <xpath expr="//field[@name='partner_shipping_id']" position="after">
                <field name="fs_no" invisible="move_type not in ('out_invoice', 'out_refund')"/>
                <field name="mrc_no" invisible="move_type not in ('out_invoice', 'out_refund')"/>
                <field name="payment_method" invisible="move_type not in ('out_invoice', 'out_refund')"/>
            </xpath>
        </field>
    </record>
</odoo>
