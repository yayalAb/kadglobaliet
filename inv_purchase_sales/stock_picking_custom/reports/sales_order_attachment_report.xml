<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_sales_order_attachment">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="stock_picking_custom.report_sales_order_attachment_document"
                    t-lang="doc.partner_id.lang or doc.company_id.partner_id.lang" />
            </t>
        </t>
    </template>

    <template id="report_sales_order_attachment_document">
        <t t-set="doc" t-value="doc.with_context(lang=doc.partner_id.lang or user.lang)" />
        <t t-set="doc_title" t-value="'Sales Attachment'" />
        <t t-set="doc_number" t-value="doc.name" />
        <t t-set="issue_number" t-value="'1'" />
        <t t-set="prepared_by" t-value="doc.get_proforma_prepared_by()" />
        <t t-set="approved_by" t-value="doc.get_proforma_approved_by()" />
        <t t-set="customer_phone" t-value="doc.partner_id.phone or doc.partner_id.mobile or ''" />
        <t t-set="customer_address" t-value="doc.partner_id.contact_address or ''" />
        <t t-call="web.external_layout">
            <t t-call="stock_picking_custom.soa_body" />
        </t>
    </template>

    <template id="soa_body">
        <style type="text/css">
            .soa-page {
                font-family: 'Noto Sans Ethiopic', 'Times New Roman', serif;
                font-size: 11px;
                color: #000;
                padding: 0 4px 12px;
            }
            .soa-title {
                font-family: 'Noto Sans Ethiopic', 'Times New Roman', serif;
                text-align: center;
                font-size: 16px;
                font-weight: bold;
                color: #c00000;
                margin: 0 0 14px 0;
                letter-spacing: 0.3px;
            }
            .soa-field {
                margin-bottom: 12px;
                font-size: 10px;
                overflow: hidden;
                width: 100%;
            }
            .soa-lbl {
                font-weight: bold;
                float: left;
                margin-right: 6px;
                padding-bottom: 3px;
                line-height: 1.35;
                font-family: 'Noto Sans Ethiopic', 'Times New Roman', serif;
            }
            .soa-und {
                display: block;
                overflow: hidden;
                border-bottom: 1px solid #000;
                min-height: 18px;
                padding: 0 0 5px 2px;
                margin-bottom: 2px;
            }
            .soa-und-dashed {
                border-bottom: 1px dashed #000;
            }
            .soa-section {
                font-family: 'Noto Sans Ethiopic', 'Times New Roman', serif;
                font-weight: bold;
                margin: 12px 0 6px 0;
                font-size: 11px;
            }
            .soa-cols {
                display: table;
                width: 100%;
                table-layout: fixed;
                margin-bottom: 10px;
                font-size: 10px;
            }
            .soa-col {
                display: table-cell;
                width: 50%;
                vertical-align: top;
                padding-right: 14px;
            }
            .soa-col-right {
                display: table-cell;
                width: 50%;
                vertical-align: top;
                padding-left: 20px;
            }
            .soa-table {
                width: 100%;
                border-collapse: collapse;
                font-size: 8.5px;
                margin-bottom: 10px;
                table-layout: fixed;
            }
            .soa-table th,
            .soa-table td {
                border: 1px solid #000;
                padding: 4px 3px;
                vertical-align: middle;
                word-wrap: break-word;
            }
            .soa-table th {
                font-family: 'Noto Sans Ethiopic', 'Times New Roman', serif;
                background: #e8e0f0;
                font-weight: bold;
                text-align: center;
                line-height: 1.25;
            }
            .soa-num { text-align: right; white-space: nowrap; }
            .soa-center { text-align: center; }
            .soa-desc { text-align: left; }
            .soa-totals {
                width: 55%;
                margin-left: auto;
                margin-top: 8px;
                margin-bottom: 10px;
                font-size: 10px;
            }
            .soa-totals-row {
                display: table;
                width: 100%;
                margin-bottom: 6px;
                table-layout: fixed;
            }
            .soa-totals-lbl {
                display: table-cell;
                font-weight: bold;
                width: 110px;
                vertical-align: bottom;
                padding-right: 8px;
                padding-bottom: 4px;
            }
            .soa-totals-val {
                display: table-cell;
                vertical-align: bottom;
            }
            .soa-line {
                border-bottom: 1px solid #000;
                min-height: 22px;
                padding: 0 2px 5px 2px;
                margin-bottom: 6px;
            }
            .soa-appr {
                margin-top: 6px;
                font-size: 10px;
            }
            .soa-appr-row {
                display: table;
                width: 100%;
                table-layout: fixed;
                margin-bottom: 14px;
                padding-bottom: 14px;
                border-bottom: 1px dotted #aaa;
            }
            .soa-appr-row:last-child {
                border-bottom: none;
                margin-bottom: 0;
                padding-bottom: 0;
            }
            .soa-appr-title {
                font-family: 'Noto Sans Ethiopic', 'Times New Roman', serif;
                display: table-cell;
                vertical-align: bottom;
                font-weight: bold;
                width: 20%;
                padding: 0 10px 4px 0;
                line-height: 1.3;
            }
            .soa-appr-slot {
                display: table-cell;
                vertical-align: bottom;
                width: 26.67%;
                padding: 0 12px 0 0;
            }
            .soa-appr-slot .soa-field { margin-bottom: 0; }
            .soa-appr-slot .soa-lbl { font-weight: normal; }
            .soa-appr-slot .soa-und { min-height: 16px; padding-bottom: 4px; }
            .soa-copy {
                margin-top: 16px;
                font-size: 10px;
                border-top: 1px solid #ccc;
                padding-top: 8px;
                text-align: center;
            }
        </style>

        <div class="page soa-page">
            <div class="oe_structure" />

            <div class="soa-title">Sales Attachment</div>

            <div class="soa-cols">
                <div class="soa-col">
                    <div class="soa-field">
                        <span class="soa-lbl">Sales Ref No:</span>
                        <div class="soa-und"><span t-field="doc.name" /></div>
                    </div>
                    <div class="soa-field">
                        <span class="soa-lbl">MRC No:</span>
                        <div class="soa-und soa-und-dashed">
                            <t t-out="doc.mrc_no or ''"/>
                        </div>
                    </div>
                    <div class="soa-field">
                        <span class="soa-lbl">ደንበኛ ስም/<br />Customer Name:</span>
                        <div class="soa-und">
                            <span t-esc="doc.partner_id.display_name or ''" />
                        </div>
                    </div>
                    <div class="soa-field">
                        <span class="soa-lbl">Phone No:</span>
                        <div class="soa-und"><span t-esc="customer_phone" /></div>
                    </div>
                </div>
                <div class="soa-col-right">
                    <div class="soa-field">
                        <span class="soa-lbl">Date:</span>
                        <div class="soa-und">
                            <span t-field="doc.date_order" t-options='{"widget": "date"}' />
                        </div>
                    </div>
                    <div class="soa-field">
                        <span class="soa-lbl">FS No:</span>
                        <div class="soa-und soa-und-dashed">
                            <t t-out="doc.fs_no or ''"/>
                        </div>
                    </div>
                    <div class="soa-field">
                        <span class="soa-lbl">Payment Method:</span>
                        <div class="soa-und">
                            <t t-out="doc.get_sales_attachment_payment_method()"/>
                        </div>
                    </div>
                    <div class="soa-field">
                        <span class="soa-lbl">TIN No:</span>
                        <div class="soa-und">
                            <span t-esc="doc.get_proforma_tin()" />
                        </div>
                    </div>
                    <div class="soa-field">
                        <span class="soa-lbl">Address:</span>
                        <div class="soa-und soa-und-dashed">
                            <span t-esc="customer_address" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="soa-section">የእቃ/የአገልግሎት አይነት /Item Details</div>

            <table class="soa-table">
                <thead style="display: table-header-group;">
                    <tr>
                        <th style="width:4%;">S.N</th>
                        <th style="width:10%;">Item Code</th>
                        <th style="width:22%;">Item Description</th>
                        <th style="width:9%;">Unit of Measure</th>
                        <th style="width:9%;">Quantity</th>
                        <th style="width:11%;">Unit Price</th>
                        <th style="width:12%;">Total Unit Price</th>
                        <th style="width:13%;">Remarks</th>
                    </tr>
                </thead>
                <tbody>
                    <t t-set="row_count" t-value="0" />
                    <t t-foreach="doc.get_proforma_order_lines()" t-as="line">
                        <t t-set="row_count" t-value="row_count + 1" />
                        <tr style="page-break-inside: avoid;">
                            <td class="soa-center"><span t-esc="row_count" /></td>
                            <td class="soa-center">
                                <span t-esc="line.product_id.default_code or ''" />
                            </td>
                            <td class="soa-desc">
                                <span t-esc="line.product_id.display_name or line.name or ''" />
                            </td>
                            <td class="soa-center">
                                <span t-esc="line.product_uom.name or ''" />
                            </td>
                            <td class="soa-num">
                                <span t-esc="'{0:,.2f}'.format(line.product_uom_qty or 0.0)" />
                            </td>
                            <td class="soa-num">
                                <span t-esc="'{0:,.2f}'.format(line.price_unit or 0.0)" />
                            </td>
                            <td class="soa-num">
                                <span t-esc="'{0:,.2f}'.format(line.price_subtotal or 0.0)" />
                            </td>
                            <td class="soa-desc">
                                <span t-esc="doc.get_proforma_line_remark(line)" />
                            </td>
                        </tr>
                    </t>
                    <t t-set="min_rows" t-value="row_count if row_count &gt;= 3 else 3" />
                    <t t-set="pad_rows" t-value="min_rows - row_count" />
                    <t t-foreach="range(pad_rows)" t-as="pad">
                        <tr>
                            <td class="soa-center"><span t-esc="row_count + pad + 1" /></td>
                            <td>&#160;</td>
                            <td>&#160;</td>
                            <td>&#160;</td>
                            <td>&#160;</td>
                            <td>&#160;</td>
                            <td>&#160;</td>
                            <td>&#160;</td>
                        </tr>
                    </t>
                </tbody>
            </table>

            <div class="soa-totals">
                <div class="soa-totals-row">
                    <span class="soa-totals-lbl">Total Birr</span>
                    <span class="soa-totals-val">
                        <div class="soa-und soa-und-dashed">
                            <span t-esc="'{0:,.2f}'.format(doc.amount_total or 0.0)" />
                        </div>
                    </span>
                </div>
                <div class="soa-totals-row">
                    <span class="soa-totals-lbl">Birr in Word</span>
                    <span class="soa-totals-val">
                        <div class="soa-und soa-und-dashed">
                            <span t-esc="doc.get_proforma_amount_in_words()" />
                        </div>
                    </span>
                </div>
            </div>

            <div class="soa-section">Term Conditions</div>
            <div class="soa-line">
                <span t-esc="doc.get_proforma_term_condition()" />
            </div>
            <div class="soa-line">&#160;</div>

            <div class="soa-section">Approval Flow</div>

            <div class="soa-appr">
                <div class="soa-appr-row">
                    <div class="soa-appr-title">Prepared By:</div>
                    <div class="soa-appr-slot">
                        <div class="soa-field">
                            <span class="soa-lbl">Name:</span>
                            <div class="soa-und">
                                <t t-if="prepared_by">
                                    <span t-field="prepared_by.name" />
                                </t>
                            </div>
                        </div>
                    </div>
                    <div class="soa-appr-slot">
                        <div class="soa-field">
                            <span class="soa-lbl">Sig:</span>
                            <div class="soa-und">
                                <t t-if="prepared_by and prepared_by.sign_signature">
                                    <img t-att-src="'data:image/png;base64,%s' % (prepared_by.sign_signature.decode())"
                                        style="max-height: 40px; max-width: 120px;" />
                                </t>
                                <t t-elif="prepared_by and prepared_by.employee_id and prepared_by.employee_id.emp_signature">
                                    <img t-att-src="'data:image/png;base64,%s' % (prepared_by.employee_id.emp_signature.decode())"
                                        style="max-height: 40px; max-width: 120px;" />
                                </t>
                            </div>
                        </div>
                    </div>
                    <div class="soa-appr-slot">
                        <div class="soa-field">
                            <span class="soa-lbl">Date:</span>
                            <div class="soa-und">
                                <t t-set="prepared_date" t-value="doc.get_proforma_prepared_date()" />
                                <t t-if="prepared_date">
                                    <span t-out="prepared_date" t-options='{"widget": "date"}' />
                                </t>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="soa-appr-row">
                    <div class="soa-appr-title">Approved By:</div>
                    <div class="soa-appr-slot">
                        <div class="soa-field">
                            <span class="soa-lbl">Name:</span>
                            <div class="soa-und">
                                <t t-if="approved_by">
                                    <span t-field="approved_by.name" />
                                </t>
                            </div>
                        </div>
                    </div>
                    <div class="soa-appr-slot">
                        <div class="soa-field">
                            <span class="soa-lbl">Sig:</span>
                            <div class="soa-und">
                                <t t-if="approved_by and approved_by.sign_signature">
                                    <img t-att-src="'data:image/png;base64,%s' % (approved_by.sign_signature.decode())"
                                        style="max-height: 40px; max-width: 120px;" />
                                </t>
                                <t t-elif="approved_by and approved_by.employee_id and approved_by.employee_id.emp_signature">
                                    <img t-att-src="'data:image/png;base64,%s' % (approved_by.employee_id.emp_signature.decode())"
                                        style="max-height: 40px; max-width: 120px;" />
                                </t>
                            </div>
                        </div>
                    </div>
                    <div class="soa-appr-slot">
                        <div class="soa-field">
                            <span class="soa-lbl">Date:</span>
                            <div class="soa-und">
                                <t t-set="approved_date" t-value="doc.get_proforma_approved_date()" />
                                <t t-if="approved_date">
                                    <span t-out="approved_date" t-options='{"widget": "date"}' />
                                </t>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="soa-copy">
                <strong>Copy Distribution:</strong>
                Original-Customer &#160;|&#160;
                1st Copy Finance &#160;|&#160;
                2nd Copy-Pad
            </div>
        </div>
    </template>
</odoo>
