<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_store_return_attachment" model="ir.actions.report">
        <field name="name">Store Return Attachment</field>
        <field name="model">stock.picking</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">stock_picking_custom.report_store_return_attachment</field>
        <field name="report_file">stock_picking_custom.report_store_return_attachment</field>
        <field name="print_report_name">'Store Return - %s' % (object.name)</field>
        <field name="binding_model_id" ref="stock.model_stock_picking" />
        <field name="binding_type">report</field>
        <field name="domain">['|', '&amp;', ('picking_type_id.code', '=', 'incoming'), ('picking_type_id.name', '=', 'Delivery Return'), '&amp;', ('picking_type_id.code', '=', 'outgoing'), ('picking_type_id.name', '=', 'Receipt Return')]</field>
    </record>

    <template id="report_store_return_attachment">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="stock_picking_custom.report_store_return_attachment_document"
                    t-lang="o.partner_id.lang or o.company_id.partner_id.lang" />
            </t>
        </t>
    </template>

    <template id="report_store_return_attachment_document">
        <t t-set="o" t-value="o.with_context(lang=o.partner_id.lang or user.lang)" />
        <t t-set="doc_title" t-value="'Store Return Attachment'" />
        <t t-set="doc_number" t-value="o.name" />
        <t t-set="issue_number" t-value="'1'" />
        <t t-set="returned_by" t-value="o.get_sra_returned_by()" />
        <t t-call="web.external_layout">
            <t t-call="stock_picking_custom.sra_body" />
        </t>
    </template>

    <template id="sra_body">
        <style type="text/css">
            .sra-page { font-family: 'Noto Sans Ethiopic', 'Times New Roman', serif; font-size: 12px; color: #000; padding: 0 4px 12px; }
            .sra-title { font-family: 'Noto Sans Ethiopic', 'Times New Roman', serif; text-align: center; font-size: 18px; font-weight: bold; color: #c00000; margin: 0 0 20px 0; }
            .sra-form-row { display: table; width: 100%; table-layout: fixed; margin-bottom: 12px; }
            .sra-form-half { display: table-cell; width: 50%; vertical-align: bottom; padding-right: 24px; }
            .sra-form-half:last-child { padding-right: 0; padding-left: 8px; }
            .sra-form-group { display: table; width: 100%; table-layout: fixed; }
            .sra-label { font-family: 'Noto Sans Ethiopic', 'Times New Roman', serif; font-weight: bold; white-space: nowrap; display: table-cell; width: 148px; vertical-align: bottom; padding-right: 8px; padding-bottom: 4px; }
            .sra-field-wrap { display: table-cell; width: auto; vertical-align: bottom; }
            .sra-field-line { display: block; width: 100%; min-height: 24px; border-bottom: 1px solid #000; padding: 3px 0 2px 10px; box-sizing: border-box; }
            .sra-label-wide { width: 200px; }
            .sra-section-title { font-family: 'Noto Sans Ethiopic', 'Times New Roman', serif; font-weight: bold; margin: 14px 0 8px 0; }
            .sra-field-full { display: block; width: 100%; margin-bottom: 8px; }
            .sra-items-table { width: 100%; border-collapse: collapse; margin-top: 4px; }
            .sra-items-table th, .sra-items-table td { border: 1px solid #000; padding: 5px 6px; vertical-align: middle; }
            .sra-items-table th { font-family: 'Noto Sans Ethiopic', 'Times New Roman', serif; font-weight: bold; text-align: center; font-size: 11px; background-color: #e8e0f0; }
            .sra-items-table tbody td { min-height: 28px; height: 28px; }
            .sra-approval-row { display: table; width: 100%; table-layout: fixed; margin-bottom: 16px; }
            .sra-approval-role { font-family: 'Noto Sans Ethiopic', 'Times New Roman', serif; display: table-cell; font-weight: bold; width: 14%; vertical-align: bottom; padding-bottom: 4px; padding-right: 6px; }
            .sra-approval-name-wrap { display: table-cell; width: 26%; vertical-align: bottom; padding-right: 14px; }
            .sra-approval-sig-label { display: table-cell; font-weight: bold; width: 4%; text-align: center; vertical-align: bottom; padding-bottom: 4px; }
            .sra-approval-sig-wrap { display: table-cell; width: 36%; vertical-align: bottom; padding-right: 14px; }
            .sra-approval-date-label { display: table-cell; font-weight: bold; width: 5%; text-align: center; vertical-align: bottom; padding-bottom: 4px; }
            .sra-approval-date-wrap { display: table-cell; width: 15%; vertical-align: bottom; }
            .sra-sig-box { width: 100%; min-height: 50px; border-bottom: 1px solid #000; text-align: center; padding-bottom: 2px; box-sizing: border-box; }
        </style>

        <div class="page sra-page">
            <div class="oe_structure" />
            <div class="sra-title">Store Return Attachment</div>

            <div class="sra-form-row">
                <div class="sra-form-half">
                    <div class="sra-form-group">
                        <span class="sra-label">Source Doc Ref. No.:</span>
                        <span class="sra-field-wrap">
                            <span class="sra-field-line">
                                <span t-esc="o.get_sra_source_doc_ref()" />
                            </span>
                        </span>
                    </div>
                </div>
                <div class="sra-form-half">
                    <div class="sra-form-group">
                        <span class="sra-label">Return Ref. No.:</span>
                        <span class="sra-field-wrap">
                            <span class="sra-field-line">
                                <span t-field="o.name" />
                            </span>
                        </span>
                    </div>
                </div>
            </div>

            <div class="sra-form-row">
                <div class="sra-form-half">
                    <div class="sra-form-group">
                        <span class="sra-label">Return Date:</span>
                        <span class="sra-field-wrap">
                            <span class="sra-field-line">
                                <t t-if="o.date_done">
                                    <span t-field="o.date_done" t-options='{"widget": "date"}' />
                                </t>
                                <t t-elif="o.scheduled_date">
                                    <span t-field="o.scheduled_date" t-options='{"widget": "date"}' />
                                </t>
                            </span>
                        </span>
                    </div>
                </div>
                <div class="sra-form-half">
                    <div class="sra-form-group">
                        <span class="sra-label">Returned By:</span>
                        <span class="sra-field-wrap">
                            <span class="sra-field-line">
                                <span t-esc="o.get_sra_returned_by_name()" />
                            </span>
                        </span>
                    </div>
                </div>
            </div>

            <div class="sra-form-row">
                <div class="sra-form-half">
                    <div class="sra-form-group">
                        <span class="sra-label">Department/Section:</span>
                        <span class="sra-field-wrap">
                            <span class="sra-field-line">
                                <span t-esc="o.get_sra_department_name()" />
                            </span>
                        </span>
                    </div>
                </div>
                <div class="sra-form-half" />
            </div>

            <div class="sra-form-row">
                <div class="sra-form-half">
                    <div class="sra-form-group">
                        <span class="sra-label sra-label-wide">From Source Location:</span>
                        <span class="sra-field-wrap">
                            <span class="sra-field-line">
                                <span t-field="o.location_id.complete_name" />
                            </span>
                        </span>
                    </div>
                </div>
                <div class="sra-form-half">
                    <div class="sra-form-group">
                        <span class="sra-label sra-label-wide">TO: Destination Location:</span>
                        <span class="sra-field-wrap">
                            <span class="sra-field-line">
                                <span t-field="o.location_dest_id.complete_name" />
                            </span>
                        </span>
                    </div>
                </div>
            </div>

            <div class="sra-section-title">የእህሉ/የእቃው አይነት /Item Details</div>

            <table class="sra-items-table">
                <thead style="display: table-header-group;">
                    <tr>
                        <th style="width: 4%;">S.N</th>
                        <th style="width: 10%;">Item Code</th>
                        <th style="width: 22%;">Item Description</th>
                        <th style="width: 10%;">Unit of Measure</th>
                        <th style="width: 11%;">Quantity Requested</th>
                        <th style="width: 11%;">Issued Quantity</th>
                        <th style="width: 10%;">Unit Price</th>
                        <th style="width: 12%;">Total Unit Price</th>
                    </tr>
                </thead>
                <tbody>
                    <t t-set="row_count" t-value="0" />
                    <t t-foreach="o.move_ids_without_package" t-as="move">
                        <t t-if="move.state != 'cancel'">
                            <t t-set="row_count" t-value="row_count + 1" />
                            <tr style="page-break-inside: avoid;">
                                <td class="text-center"><span t-esc="row_count" /></td>
                                <td><span t-field="move.product_id.default_code" /></td>
                                <td><span t-field="move.product_id.name" /></td>
                                <td class="text-center"><span t-field="move.product_uom.name" /></td>
                                <td class="text-end">
                                    <span t-esc="'{0:,.2f}'.format(move.product_uom_qty)" />
                                </td>
                                <td class="text-end">
                                    <span t-esc="'{0:,.2f}'.format(move.quantity)" />
                                </td>
                                <td class="text-end">
                                    <span t-esc="'{0:,.2f}'.format(move.line_unit_price or 0.0)" />
                                </td>
                                <td class="text-end">
                                    <span t-esc="'{0:,.2f}'.format(move.line_subtotal or 0.0)" />
                                </td>
                            </tr>
                        </t>
                    </t>
                    <t t-set="min_rows" t-value="3" />
                    <t t-set="pad_rows" t-value="min_rows - row_count if row_count &lt; min_rows else 0" />
                    <t t-foreach="range(pad_rows)" t-as="pad">
                        <tr>
                            <td class="text-center"><span t-esc="row_count + pad + 1" /></td>
                            <td>&#160;</td>
                            <td>&#160;</td>
                            <td>&#160;</td>
                            <td>&#160;</td>
                            <td>&#160;</td>
                            <td>&#160;</td>
                            <td>&#160;</td>
                        </tr>
                    </t>
                </tbody>
            </table>

            <div class="sra-section-title">
                የተመለስበት/መነሻ ምክንያት Justification / Purpose/Reason
            </div>

            <div class="sra-field-full">
                <span class="sra-field-line" style="min-height: 28px;">
                    <span t-esc="o.get_sra_justification()" />
                </span>
            </div>
            <div class="sra-field-full">
                <span class="sra-field-line" style="min-height: 28px;" />
            </div>

            <div class="sra-section-title">Approval Flow</div>

            <div class="sra-approval-row">
                <div class="sra-approval-role">Returned By:</div>
                <div class="sra-approval-name-wrap">
                    <span class="sra-field-line">
                        <t t-if="returned_by">
                            <span t-field="returned_by.name" />
                        </t>
                    </span>
                </div>
                <div class="sra-approval-sig-label">Sig:</div>
                <div class="sra-approval-sig-wrap">
                    <div class="sra-sig-box">
                        <t t-if="returned_by and returned_by.sign_signature">
                            <img t-att-src="'data:image/png;base64,%s' % (returned_by.sign_signature.decode())"
                                style="max-height: 46px; max-width: 140px;" />
                        </t>
                        <t t-elif="returned_by and returned_by.employee_id and returned_by.employee_id.emp_signature">
                            <img t-att-src="'data:image/png;base64,%s' % (returned_by.employee_id.emp_signature.decode())"
                                style="max-height: 46px; max-width: 140px;" />
                        </t>
                    </div>
                </div>
                <div class="sra-approval-date-label">Date:</div>
                <div class="sra-approval-date-wrap">
                    <span class="sra-field-line">
                        <t t-if="o.date_done">
                            <span t-field="o.date_done" t-options='{"widget": "date"}' />
                        </t>
                    </span>
                </div>
            </div>

            <div class="sra-approval-row">
                <div class="sra-approval-role">Approved By:</div>
                <div class="sra-approval-name-wrap">
                    <span class="sra-field-line">
                        <span t-field="o.approved_by.name" />
                    </span>
                </div>
                <div class="sra-approval-sig-label">Sig:</div>
                <div class="sra-approval-sig-wrap">
                    <div class="sra-sig-box">
                        <t t-if="o.approved_by and o.approved_by.sign_signature">
                            <img t-att-src="'data:image/png;base64,%s' % (o.approved_by.sign_signature.decode())"
                                style="max-height: 46px; max-width: 140px;" />
                        </t>
                        <t t-elif="o.approved_by and o.approved_by.employee_id and o.approved_by.employee_id.emp_signature">
                            <img t-att-src="'data:image/png;base64,%s' % (o.approved_by.employee_id.emp_signature.decode())"
                                style="max-height: 46px; max-width: 140px;" />
                        </t>
                    </div>
                </div>
                <div class="sra-approval-date-label">Date:</div>
                <div class="sra-approval-date-wrap">
                    <span class="sra-field-line">
                        <t t-if="o.date_done">
                            <span t-field="o.date_done" t-options='{"widget": "date"}' />
                        </t>
                    </span>
                </div>
            </div>
        </div>
    </template>
</odoo>
