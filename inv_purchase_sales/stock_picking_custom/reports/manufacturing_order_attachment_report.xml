<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_manufacturing_order_attachment">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="stock_picking_custom.report_manufacturing_order_attachment_document"
                    t-lang="o.company_id.partner_id.lang" />
            </t>
        </t>
    </template>

    <template id="report_manufacturing_order_attachment_document">
        <t t-set="o" t-value="o.with_context(lang=o.company_id.partner_id.lang or user.lang)" />
        <t t-set="doc_title" t-value="'Manufacturing Order Attachment'" />
        <t t-set="doc_number" t-value="o.name" />
        <t t-set="issue_number" t-value="'1'" />
        <t t-set="prepared_by" t-value="o.get_moa_prepared_by()" />
        <t t-set="approved_by" t-value="o.get_moa_approved_by()" />
        <t t-call="web.external_layout">
            <t t-call="stock_picking_custom.moa_body" />
        </t>
    </template>

    <template id="moa_body">
        <style type="text/css">
            .moa-page {
                font-family: 'Noto Sans Ethiopic', 'Times New Roman', serif;
                font-size: 10px;
                color: #000;
                padding: 0 4px 12px;
            }
            .moa-title {
                font-family: 'Noto Sans Ethiopic', 'Times New Roman', serif;
                text-align: center;
                font-size: 16px;
                font-weight: bold;
                color: #c00000;
                margin: 0 0 14px 0;
            }
            .moa-row4 {
                display: table;
                width: 100%;
                table-layout: fixed;
                margin-bottom: 10px;
                font-size: 9.5px;
            }
            .moa-cell {
                display: table-cell;
                width: 25%;
                vertical-align: bottom;
                padding-right: 10px;
            }
            .moa-cell:last-child { padding-right: 0; }
            .moa-field { margin-bottom: 10px; overflow: hidden; }
            .moa-lbl {
                font-weight: bold;
                float: left;
                margin-right: 4px;
                line-height: 1.3;
                font-family: 'Noto Sans Ethiopic', 'Times New Roman', serif;
            }
            .moa-und {
                display: block;
                overflow: hidden;
                border-bottom: 1px solid #000;
                min-height: 16px;
                padding: 0 0 4px 2px;
            }
            .moa-und-dashed { border-bottom: 1px dashed #000; }
            .moa-cols {
                display: table;
                width: 100%;
                table-layout: fixed;
                margin-bottom: 10px;
                font-size: 9.5px;
            }
            .moa-col {
                display: table-cell;
                width: 50%;
                vertical-align: top;
                padding-right: 14px;
            }
            .moa-col-right {
                display: table-cell;
                width: 50%;
                vertical-align: top;
                padding-left: 16px;
            }
            .moa-section {
                font-family: 'Noto Sans Ethiopic', 'Times New Roman', serif;
                font-weight: bold;
                margin: 12px 0 6px 0;
                font-size: 11px;
            }
            .moa-table {
                width: 100%;
                border-collapse: collapse;
                font-size: 8.5px;
                margin-bottom: 10px;
                table-layout: fixed;
            }
            .moa-table th,
            .moa-table td {
                border: 1px solid #000;
                padding: 4px 3px;
                vertical-align: middle;
                word-wrap: break-word;
            }
            .moa-table th {
                font-family: 'Noto Sans Ethiopic', 'Times New Roman', serif;
                background: #e8e0f0;
                font-weight: bold;
                text-align: center;
                line-height: 1.2;
            }
            .moa-num { text-align: right; white-space: nowrap; }
            .moa-center { text-align: center; }
            .moa-desc { text-align: left; }
            .moa-line {
                border-bottom: 1px solid #000;
                min-height: 22px;
                padding: 0 2px 5px 2px;
                margin-bottom: 6px;
            }
            .moa-appr { margin-top: 6px; font-size: 10px; }
            .moa-appr-row {
                display: table;
                width: 100%;
                table-layout: fixed;
                margin-bottom: 14px;
                padding-bottom: 14px;
                border-bottom: 1px dotted #aaa;
            }
            .moa-appr-row:last-child {
                border-bottom: none;
                margin-bottom: 0;
                padding-bottom: 0;
            }
            .moa-appr-title {
                font-family: 'Noto Sans Ethiopic', 'Times New Roman', serif;
                display: table-cell;
                font-weight: bold;
                width: 20%;
                vertical-align: bottom;
                padding: 0 10px 4px 0;
            }
            .moa-appr-slot {
                display: table-cell;
                vertical-align: bottom;
                width: 26.67%;
                padding: 0 12px 0 0;
            }
            .moa-appr-slot .moa-field { margin-bottom: 0; }
            .moa-appr-slot .moa-lbl { font-weight: normal; }
            .moa-appr-slot .moa-und { min-height: 16px; padding-bottom: 4px; }
            .moa-copy {
                margin-top: 16px;
                font-size: 10px;
                border-top: 1px solid #ccc;
                padding-top: 8px;
                text-align: center;
            }
        </style>

        <div class="page moa-page">
            <div class="oe_structure" />

            <div class="moa-title">ምርት / Manufacturing Order Attachment</div>

            <div class="moa-row4">
                <div class="moa-cell">
                    <div class="moa-field">
                        <span class="moa-lbl">Source Ref No:</span>
                        <div class="moa-und"><span t-esc="o.origin or ''" /></div>
                    </div>
                </div>
                <div class="moa-cell">
                    <div class="moa-field">
                        <span class="moa-lbl">Date:</span>
                        <div class="moa-und">
                            <t t-if="o.date_start">
                                <span t-field="o.date_start" t-options='{"widget": "date"}' />
                            </t>
                        </div>
                    </div>
                </div>
                <div class="moa-cell">
                    <div class="moa-field">
                        <span class="moa-lbl">MO Ref No:</span>
                        <div class="moa-und"><span t-field="o.name" /></div>
                    </div>
                </div>
                <div class="moa-cell">
                    <div class="moa-field">
                        <span class="moa-lbl">production Date:</span>
                        <div class="moa-und">
                            <t t-if="o.date_finished">
                                <span t-field="o.date_finished" t-options='{"widget": "date"}' />
                            </t>
                        </div>
                    </div>
                </div>
            </div>

            <div class="moa-cols">
                <div class="moa-col">
                    <div class="moa-field">
                        <span class="moa-lbl">የሚመረቱበት የድርጅት ስም/<br />Name:</span>
                        <div class="moa-und"><span t-field="o.company_id.name" /></div>
                    </div>
                    <div class="moa-field">
                        <span class="moa-lbl">Machine Name:</span>
                        <div class="moa-und"><span t-esc="o.get_moa_machine_name()" /></div>
                    </div>
                    <div class="moa-field">
                        <span class="moa-lbl">Finished Goods Name:</span>
                        <div class="moa-und"><span t-esc="o.product_id.display_name or ''" /></div>
                    </div>
                    <div class="moa-field">
                        <span class="moa-lbl">Actual Produced Quantity:</span>
                        <div class="moa-und">
                            <span t-esc="'{0:,.2f}'.format(o.qty_produced or 0.0)" />
                            <t t-if="o.product_uom_id">
                                <span t-esc="' %s' % (o.product_uom_id.name or '')" />
                            </t>
                        </div>
                    </div>
                </div>
                <div class="moa-col-right">
                    <div class="moa-field">
                        <span class="moa-lbl">Tin No:</span>
                        <div class="moa-und">
                            <span t-esc="o.company_id.vat or o.company_id.partner_id.vat or ''" />
                        </div>
                    </div>
                    <div class="moa-field">
                        <span class="moa-lbl">Operator Name:</span>
                        <div class="moa-und">
                            <t t-if="o.user_id"><span t-field="o.user_id.name" /></t>
                        </div>
                    </div>
                    <div class="moa-field">
                        <span class="moa-lbl">Planned Production Quantity:</span>
                        <div class="moa-und">
                            <span t-esc="'{0:,.2f}'.format(o.product_qty or 0.0)" />
                            <t t-if="o.product_uom_id">
                                <span t-esc="' %s' % (o.product_uom_id.name or '')" />
                            </t>
                        </div>
                    </div>
                    <div class="moa-field">
                        <span class="moa-lbl">Warehouse:</span>
                        <div class="moa-und">
                            <span t-esc="o.location_dest_id.complete_name or ''" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="moa-row4">
                <div class="moa-cell">
                    <div class="moa-field">
                        <span class="moa-lbl">Phone No:</span>
                        <div class="moa-und"><span t-esc="o.get_moa_company_phone()" /></div>
                    </div>
                </div>
                <div class="moa-cell">
                    <div class="moa-field">
                        <span class="moa-lbl">start time:</span>
                        <div class="moa-und">
                            <t t-if="o.date_start">
                                <span t-field="o.date_start" t-options='{"widget": "datetime"}' />
                            </t>
                        </div>
                    </div>
                </div>
                <div class="moa-cell">
                    <div class="moa-field">
                        <span class="moa-lbl">End time:</span>
                        <div class="moa-und">
                            <t t-if="o.date_finished">
                                <span t-field="o.date_finished" t-options='{"widget": "datetime"}' />
                            </t>
                        </div>
                    </div>
                </div>
                <div class="moa-cell">
                    <div class="moa-field">
                        <span class="moa-lbl">Address:</span>
                        <div class="moa-und moa-und-dashed">
                            <span t-esc="o.get_moa_company_address()" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="moa-section">Raw Material Consumption</div>
            <table class="moa-table">
                <thead style="display: table-header-group;">
                    <tr>
                        <th style="width:5%;">No</th>
                        <th style="width:28%;">Raw Material</th>
                        <th style="width:14%;">Planned Qty</th>
                        <th style="width:14%;">Consumed Qty</th>
                        <th style="width:12%;">UOM</th>
                        <th style="width:17%;">Remark</th>
                    </tr>
                </thead>
                <tbody>
                    <t t-set="rm_count" t-value="0" />
                    <t t-foreach="o.get_moa_raw_material_moves()" t-as="move">
                        <t t-set="rm_count" t-value="rm_count + 1" />
                        <tr style="page-break-inside: avoid;">
                            <td class="moa-center"><span t-esc="rm_count" /></td>
                            <td class="moa-desc">
                                <span t-esc="move.product_id.display_name or move.name or ''" />
                            </td>
                            <td class="moa-num">
                                <span t-esc="'{0:,.2f}'.format(move.product_uom_qty or 0.0)" />
                            </td>
                            <td class="moa-num">
                                <span t-esc="'{0:,.2f}'.format(o.get_moa_consumed_qty(move))" />
                            </td>
                            <td class="moa-center">
                                <span t-esc="move.product_uom.name or ''" />
                            </td>
                            <td class="moa-desc">&#160;</td>
                        </tr>
                    </t>
                    <t t-set="rm_min" t-value="rm_count if rm_count &gt;= 3 else 3" />
                    <t t-set="rm_pad" t-value="rm_min - rm_count" />
                    <t t-foreach="range(rm_pad)" t-as="pad">
                        <tr>
                            <td class="moa-center"><span t-esc="rm_count + pad + 1" /></td>
                            <td>&#160;</td>
                            <td>&#160;</td>
                            <td>&#160;</td>
                            <td>&#160;</td>
                            <td>&#160;</td>
                        </tr>
                    </t>
                </tbody>
            </table>

            <div class="moa-section">By-Product Information</div>
            <table class="moa-table">
                <thead style="display: table-header-group;">
                    <tr>
                        <th style="width:5%;">No</th>
                        <th style="width:35%;">By-Product Name</th>
                        <th style="width:18%;">Quantity</th>
                        <th style="width:15%;">UOM</th>
                        <th style="width:17%;">Remark</th>
                    </tr>
                </thead>
                <tbody>
                    <t t-set="bp_count" t-value="0" />
                    <t t-foreach="o.get_moa_byproduct_moves()" t-as="move">
                        <t t-set="bp_count" t-value="bp_count + 1" />
                        <tr style="page-break-inside: avoid;">
                            <td class="moa-center"><span t-esc="bp_count" /></td>
                            <td class="moa-desc">
                                <span t-esc="move.product_id.display_name or move.name or ''" />
                            </td>
                            <td class="moa-num">
                                <span t-esc="'{0:,.2f}'.format(o.get_moa_byproduct_qty(move))" />
                            </td>
                            <td class="moa-center">
                                <span t-esc="move.product_uom.name or ''" />
                            </td>
                            <td class="moa-desc">&#160;</td>
                        </tr>
                    </t>
                    <t t-set="bp_min" t-value="bp_count if bp_count &gt;= 2 else 2" />
                    <t t-set="bp_pad" t-value="bp_min - bp_count" />
                    <t t-foreach="range(bp_pad)" t-as="pad">
                        <tr>
                            <td class="moa-center"><span t-esc="bp_count + pad + 1" /></td>
                            <td>&#160;</td>
                            <td>&#160;</td>
                            <td>&#160;</td>
                            <td>&#160;</td>
                        </tr>
                    </t>
                </tbody>
            </table>

            <div class="moa-section">የተመረተበት/የተበላሸበት ምክንያት</div>
            <div class="moa-line">
                <span t-field="o.mo_attachment_reason" />
            </div>
            <div class="moa-line">&#160;</div>

            <div class="moa-section">Approval Flow</div>
            <div class="moa-appr">
                <div class="moa-appr-row">
                    <div class="moa-appr-title">Prepared By:</div>
                    <div class="moa-appr-slot">
                        <div class="moa-field">
                            <span class="moa-lbl">Name:</span>
                            <div class="moa-und">
                                <t t-if="prepared_by"><span t-field="prepared_by.name" /></t>
                            </div>
                        </div>
                    </div>
                    <div class="moa-appr-slot">
                        <div class="moa-field">
                            <span class="moa-lbl">Sig:</span>
                            <div class="moa-und">
                                <t t-if="prepared_by and prepared_by.sign_signature">
                                    <img t-att-src="'data:image/png;base64,%s' % (prepared_by.sign_signature.decode())"
                                        style="max-height: 40px; max-width: 120px;" />
                                </t>
                                <t t-elif="prepared_by and prepared_by.employee_id and prepared_by.employee_id.emp_signature">
                                    <img t-att-src="'data:image/png;base64,%s' % (prepared_by.employee_id.emp_signature.decode())"
                                        style="max-height: 40px; max-width: 120px;" />
                                </t>
                            </div>
                        </div>
                    </div>
                    <div class="moa-appr-slot">
                        <div class="moa-field">
                            <span class="moa-lbl">Date:</span>
                            <div class="moa-und">
                                <t t-if="o.create_date">
                                    <span t-field="o.create_date" t-options='{"widget": "date"}' />
                                </t>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="moa-appr-row">
                    <div class="moa-appr-title">Approved By:</div>
                    <div class="moa-appr-slot">
                        <div class="moa-field">
                            <span class="moa-lbl">Name:</span>
                            <div class="moa-und">
                                <t t-if="approved_by"><span t-field="approved_by.name" /></t>
                            </div>
                        </div>
                    </div>
                    <div class="moa-appr-slot">
                        <div class="moa-field">
                            <span class="moa-lbl">Sig:</span>
                            <div class="moa-und">
                                <t t-if="approved_by and approved_by.sign_signature">
                                    <img t-att-src="'data:image/png;base64,%s' % (approved_by.sign_signature.decode())"
                                        style="max-height: 40px; max-width: 120px;" />
                                </t>
                                <t t-elif="approved_by and approved_by.employee_id and approved_by.employee_id.emp_signature">
                                    <img t-att-src="'data:image/png;base64,%s' % (approved_by.employee_id.emp_signature.decode())"
                                        style="max-height: 40px; max-width: 120px;" />
                                </t>
                            </div>
                        </div>
                    </div>
                    <div class="moa-appr-slot">
                        <div class="moa-field">
                            <span class="moa-lbl">Date:</span>
                            <div class="moa-und">
                                <t t-if="o.date_finished">
                                    <span t-field="o.date_finished" t-options='{"widget": "date"}' />
                                </t>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="moa-copy">
                <strong>Copy Distribution:</strong>
                Original-Store &#160;|&#160; 1st Copy Finance
            </div>
        </div>
    </template>
</odoo>
