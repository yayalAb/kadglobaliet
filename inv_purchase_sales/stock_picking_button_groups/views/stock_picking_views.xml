<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_picking_form_button_groups" model="ir.ui.view">
        <field name="name">stock.picking.form.button.groups</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header/button[@name='action_confirm']" position="attributes">
                <attribute name="groups">stock_picking_button_groups.group_stock_picking_mark_todo</attribute>
            </xpath>

            <xpath expr="//header/button[@name='action_assign']" position="attributes">
                <attribute name="groups">stock_picking_button_groups.group_stock_picking_check_availability</attribute>
            </xpath>

            <xpath expr="//header/button[@name='button_validate']" position="attributes">
                <attribute name="groups">stock_picking_button_groups.group_stock_picking_validate</attribute>
            </xpath>

            <xpath expr="//header/button[@data-hotkey='k']" position="attributes">
                <attribute name="groups">stock_picking_button_groups.group_stock_picking_return</attribute>
            </xpath>

            <xpath expr="//header/button[@name='action_cancel']" position="attributes">
                <attribute name="groups">stock_picking_button_groups.group_stock_picking_cancel</attribute>
            </xpath>
        </field>
    </record>
</odoo>
