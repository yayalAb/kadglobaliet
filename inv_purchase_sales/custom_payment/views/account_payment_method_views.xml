<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_account_payment_method_tree_custom" model="ir.ui.view">
        <field name="name">account.payment.method.list.custom</field>
        <field name="model">account.payment.method</field>
        <field name="arch" type="xml">
            <list string="Payment Methods" editable="bottom">
                <field name="name"/>
                <field name="code"/>
                <field name="payment_type"/>
            </list>
        </field>
    </record>

    <record id="view_account_payment_method_form_custom" model="ir.ui.view">
        <field name="name">account.payment.method.form.custom</field>
        <field name="model">account.payment.method</field>
        <field name="arch" type="xml">
            <form string="Payment Method">
                <sheet>
                    <group>
                        <field name="name" placeholder="e.g. Tele Birr"/>
                        <field name="code" placeholder="e.g. tele_birr"/>
                        <field name="payment_type"/>
                    </group>
                    <div class="text-muted">
                        Use the same code for inbound and outbound when the method applies to both directions.
                        After saving, add the method on each bank journal under Incoming or Outgoing Payments.
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_account_payment_method_custom" model="ir.actions.act_window">
        <field name="name">Payment Methods</field>
        <field name="res_model">account.payment.method</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_account_payment_method_tree_custom"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Define payment methods such as Cash, Cheque, CPO, and Tele Birr.
            </p>
            <p>
                Then link them on each journal under Incoming Payments or Outgoing Payments.
            </p>
        </field>
    </record>

    <menuitem id="menu_account_payment_method_custom"
              name="Payment Methods"
              parent="account.account_banks_menu"
              action="action_account_payment_method_custom"
              sequence="2"
              groups="account.group_account_manager"/>
</odoo>
