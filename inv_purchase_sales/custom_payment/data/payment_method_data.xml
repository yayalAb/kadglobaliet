<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Inbound (customer receipts) -->
        <record id="account_payment_method_cash_in" model="account.payment.method">
            <field name="name">Cash</field>
            <field name="code">cash</field>
            <field name="payment_type">inbound</field>
        </record>
        <record id="account_payment_method_cheque_in" model="account.payment.method">
            <field name="name">Cheque</field>
            <field name="code">cheque</field>
            <field name="payment_type">inbound</field>
        </record>
        <record id="account_payment_method_cpo_in" model="account.payment.method">
            <field name="name">CPO</field>
            <field name="code">cpo</field>
            <field name="payment_type">inbound</field>
        </record>
        <record id="account_payment_method_tele_birr_in" model="account.payment.method">
            <field name="name">Tele Birr</field>
            <field name="code">tele_birr</field>
            <field name="payment_type">inbound</field>
        </record>

        <!-- Outbound (vendor payments) -->
        <record id="account_payment_method_cash_out" model="account.payment.method">
            <field name="name">Cash</field>
            <field name="code">cash</field>
            <field name="payment_type">outbound</field>
        </record>
        <record id="account_payment_method_cheque_out" model="account.payment.method">
            <field name="name">Cheque</field>
            <field name="code">cheque</field>
            <field name="payment_type">outbound</field>
        </record>
        <record id="account_payment_method_cpo_out" model="account.payment.method">
            <field name="name">CPO</field>
            <field name="code">cpo</field>
            <field name="payment_type">outbound</field>
        </record>
        <record id="account_payment_method_tele_birr_out" model="account.payment.method">
            <field name="name">Tele Birr</field>
            <field name="code">tele_birr</field>
            <field name="payment_type">outbound</field>
        </record>
    </data>
</odoo>
