<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="sale_order_form_service_request" model="ir.ui.view">
        <field name="name">sale.order.form.service.request</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <field name="customer_vetting_can_create_delivery" invisible="1"/>
                <button name="action_open_create_delivery_wizard"
                        type="object"
                        string="Create Delivery Order"
                        class="btn-secondary"
                        groups="stock.group_stock_user"
                        invisible="not customer_vetting_can_create_delivery"/>
            </xpath>
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_product_detail_receipts"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-truck"
                        groups="stock.group_stock_user"
                        invisible="product_detail_receipt_count == 0">
                    <field name="product_detail_receipt_count" widget="statinfo" string="Receipts"/>
                </button>
                <button name="action_view_customer_vetting_deliveries"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-paper-plane"
                        groups="stock.group_stock_user"
                        invisible="customer_vetting_delivery_count == 0">
                    <field name="customer_vetting_delivery_count" widget="statinfo" string="Deliveries"/>
                </button>
            </xpath>
            <xpath expr="//group[@name='sale_header']/group[@name='partner_details']/field[@name='partner_id']" position="after">
                <field name="service_request_id"
                       readonly="1"
                       invisible="not service_request_id"
                       options="{'no_create': True, 'no_create_edit': True}"/>
                <field name="required_filtering_quality"
                       readonly="state in ('sale', 'cancel')"/>
            </xpath>
            <xpath expr="//page[@name='order_lines']" position="after">
                <page string="Product detail" name="product_detail_vetting"
                      invisible="not service_request_id">
                    <field name="vetting_detail_line_ids"
                           nolabel="1"
                           mode="list"
                           domain="[('detail_type', '!=', 'finished')]">
                        <list editable="bottom">
                            <field name="source_sale_line_id"
                                   domain="[('order_id', '=', parent.id), ('display_type', '=', False), ('product_id.type', '=', 'service')]"
                                  options="{'no_create': True}" />
                            <field name="detail_type"/>
                            <field name="product_id"/>
                            <field name="name" string="Description"/>
                            <field name="product_uom" groups="uom.group_uom"/>
                            <field name="product_uom_qty" string="Quantity"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
