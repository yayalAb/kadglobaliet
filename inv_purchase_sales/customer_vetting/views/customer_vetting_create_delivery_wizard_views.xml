<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="customer_vetting_create_delivery_wizard_form" model="ir.ui.view">
        <field name="name">customer.vetting.create.delivery.wizard.form</field>
        <field name="model">customer.vetting.create.delivery.wizard</field>
        <field name="arch" type="xml">
            <form string="Create delivery order">
                <group>
                    <field name="sale_order_id"/>
                </group>
                <field name="line_ids" nolabel="1">
                    <list editable="bottom" create="0" delete="0">
                        <field name="selected"/>
                        <field name="line_type"/>
                        <field name="product_id"/>
                        <field name="product_uom_id" groups="uom.group_uom"/>
                        <field name="available_qty"/>
                        <field name="product_uom_qty"/>
                        <field name="mrp_production_ids" widget="many2many_tags" optional="hide"/>
                    </list>
                </field>
                <footer>
                    <button name="action_create_delivery"
                            type="object"
                            string="Create delivery order"
                            class="btn-primary"/>
                    <button string="Cancel" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
