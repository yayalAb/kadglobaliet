<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_service_request_list" model="ir.ui.view">
        <field name="name">service.request.list</field>
        <field name="model">service.request</field>
        <field name="arch" type="xml">
            <list string="Service requests"
                  decoration-muted="state == 'cancel'"
                  decoration-danger="state == 'rejected'"
                  decoration-success="state == 'approved'">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="required_filtering_quality" optional="show"/>
                <field name="date"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'approved'"
                       decoration-info="state in ('submitted', 'reviewed')"
                       decoration-danger="state in ('rejected', 'cancel')"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_service_request_form" model="ir.ui.view">
        <field name="name">service.request.form</field>
        <field name="model">service.request</field>
        <field name="arch" type="xml">
            <form string="Service request">
                <header>
                    <button name="action_submit" string="Submit" type="object" class="oe_highlight"
                            invisible="state != 'draft'"
                            groups="sales_team.group_sale_salesman"/>
                    <button name="action_review" string="Mark reviewed" type="object" class="oe_highlight"
                            invisible="state != 'submitted'"
                            groups="customer_vetting.group_customer_vetting_manager"/>
                    <button name="action_approve" string="Approve" type="object" class="oe_highlight"
                            invisible="state != 'reviewed'"
                            groups="customer_vetting.group_customer_vetting_manager"/>
                    <button name="action_reject" string="Reject" type="object"
                            invisible="state not in ('submitted', 'reviewed')"
                            groups="customer_vetting.group_customer_vetting_manager"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            invisible="state in ('approved', 'rejected', 'cancel')"
                            groups="sales_team.group_sale_salesman"/>
                    <button name="action_reset_to_draft" string="Reset to draft" type="object"
                            invisible="state not in ('rejected', 'cancel')"
                            groups="customer_vetting.group_customer_vetting_manager"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,reviewed,approved,rejected,cancel"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_sale_order" type="object"
                                class="oe_stat_button" icon="fa-shopping-cart"
                                invisible="not sale_order_id"
                                groups="sales_team.group_sale_salesman">
                            <field name="sale_order_id" widget="statinfo" string="Sales Order"/>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="partner_id" context="{'default_customer_rank': 1}"
                                   readonly="state != 'draft'"/>
                            <field name="date" readonly="state != 'draft'"/>
                            <field name="required_filtering_quality" readonly="state != 'draft'"/>
                        </group>
                        <group>
                            <field name="company_id" groups="base.group_multi_company"
                                   readonly="state != 'draft'"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Services" name="lines">
                            <field name="line_ids" nolabel="1" readonly="state != 'draft'">
                                <list editable="bottom">
                                    <field name="product_id" options="{'no_create': True}"/>
                                    <field name="name"/>
                                    <field name="product_uom_qty"/>
                                    <field name="product_uom_id"/>
                                    <field name="product_uom_category_id" column_invisible="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_service_request_search" model="ir.ui.view">
        <field name="name">service.request.search</field>
        <field name="model">service.request</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="required_filtering_quality"/>
                <field name="date"/>
                <filter name="filter_draft" string="Draft" domain="[('state', '=', 'draft')]"/>
                <filter name="filter_submitted" string="Submitted" domain="[('state', '=', 'submitted')]"/>
                <filter name="filter_reviewed" string="Reviewed" domain="[('state', '=', 'reviewed')]"/>
                <filter name="filter_approved" string="Approved" domain="[('state', '=', 'approved')]"/>
                <filter name="filter_rejected" string="Rejected" domain="[('state', '=', 'rejected')]"/>
                <filter name="filter_cancel" string="Cancelled" domain="[('state', '=', 'cancel')]"/>
                <separator/>
                <filter name="filter_open" string="Open"
                        domain="[('state', 'in', ('draft', 'submitted', 'reviewed'))]"/>
                <group expand="0" string="Group by">
                    <filter name="group_partner" string="Customer" context="{'group_by': 'partner_id'}"/>
                    <filter name="group_date" string="Date" context="{'group_by': 'date'}"/>
                    <filter name="group_state" string="Status" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_service_request" model="ir.actions.act_window">
        <field name="name">Service requests</field>
        <field name="res_model">service.request</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Create a new service request.</p>
        </field>
    </record>

    <menuitem id="menu_service_request"
              name="Service requests"
              parent="sale.sale_menu_root"
              action="action_service_request"
              sequence="25"/>
</odoo>
