<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_view_vetting" model="ir.ui.view">
        <field name="name">product.template.form.vetting</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//form/sheet/notebook" position="inside">
                <page string="Vetting" name="customer_vetting" invisible="type != 'service'">
                    <group>
                        <group>
                            <field name="vetting_other_product_id"
                                   domain="[('type', '!=', 'service')]"
                                   options="{'no_create': True}"/>
                            <field name="vetting_finished_product_id"
                                   domain="[('type', '!=', 'service')]"
                                   options="{'no_create': True}"/>
                            <field name="vetting_residue_product_id"
                                   domain="[('type', '!=', 'service')]"
                                   options="{'no_create': True}"/>
                            <field name="bag_id"
                                   domain="[('type', '!=', 'service')]"
                                   options="{'no_create': True}"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
