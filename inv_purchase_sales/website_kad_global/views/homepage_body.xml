<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="homepage_body" name="KAD Homepage Body">

        <!-- HERO — full-bleed trade photography -->
        <section class="kad-hero kad-style kad-style--cinematic">
            <div class="kad-hero__media" aria-hidden="true">
                <img src="/website_kad_global/static/src/img/hero_port.jpg"
                     alt=""
                     class="kad-hero__photo"
                     loading="eager"/>
                <div class="kad-hero__shade"/>
                <span class="kad-orb kad-orb--1"/>
                <span class="kad-orb kad-orb--2"/>
            </div>

            <div class="container-fluid kad-hero__inner">
                <div class="kad-hero__brand" data-kad-anim="fade-up" data-kad-delay="0">
                    <img src="/website_kad_global/static/src/img/kad_logo.png"
                         alt="KAD Import &amp; Export"
                         class="kad-hero__logo"/>
                    <p class="kad-hero__eyebrow" aria-label="Kalkidan Abebaw Derso Import and Export KADIE">
                        <span class="kad-word kad-word--s1" style="--i:0">Kalkidan</span>
                        <span class="kad-word kad-word--s2" style="--i:1">Abebaw</span>
                        <span class="kad-word kad-word--s3" style="--i:2">Derso</span>
                        <span class="kad-word kad-word--s4" style="--i:3">Import</span>
                        <span class="kad-amp kad-word--s5" style="--i:4">&amp;</span>
                        <span class="kad-word kad-word--s6" style="--i:5">Export</span>
                        <span class="kad-word kad-word--accent kad-word--s7" style="--i:6">(KADIE)</span>
                    </p>
                </div>

                <div class="kad-hero__copy kad-hero__copy--wide">
                    <h1 class="kad-hero__title" data-kad-anim="fade-up" data-kad-delay="140">
                        Bridging Markets,<br/>
                        <span class="kad-hero__title-accent">Connecting Worlds.</span>
                    </h1>
                    <p class="kad-hero__lead" data-kad-anim="fade-up" data-kad-delay="220">
                        Connecting Ethiopian products with global markets while delivering
                        high-quality imported goods for industrial, commercial, and construction sectors.
                    </p>
                    <div class="kad-hero__actions" data-kad-anim="fade-up" data-kad-delay="300">
                        <a href="#contact" class="kad-btn kad-btn--primary">
                            <span>Get Quote</span>
                            <span class="kad-btn__shine" aria-hidden="true"/>
                        </a>
                        <a href="#about" class="kad-btn kad-btn--ghost">Learn More</a>
                    </div>
                    <div class="kad-hero__chips" data-kad-anim="fade-up" data-kad-delay="380">
                        <span class="kad-chip">Export</span>
                        <span class="kad-chip">Import</span>
                        <span class="kad-chip">Logistics</span>
                        <span class="kad-chip">Global Trade</span>
                    </div>
                </div>
            </div>
            <div class="kad-hero__scroll" aria-hidden="true"><span/></div>
        </section>

