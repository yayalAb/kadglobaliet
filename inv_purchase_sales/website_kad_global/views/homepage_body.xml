                <div class="kad-marquee__track kad-marquee__track--right">
                    <span class="kad-pill">Logistics</span>
                    <span class="kad-pill">Customs</span>
                    <span class="kad-pill">Partnerships</span>
                    <span class="kad-pill">Quality</span>
                    <span class="kad-pill kad-pill--accent">Global Trade</span>
