<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="contact_thanks" name="KAD Contact Thank You">
        <t t-call="website.layout">
            <t t-set="additional_title">Thank You | KAD Import &amp; Export</t>
            <div id="wrap" class="oe_structure kad-site">
                <section class="kad-section">
                    <div class="container text-center" style="max-width: 640px;">
                        <img src="/website_kad_global/static/src/img/kad_logo.png"
                             alt="KAD"
                             class="kad-hero__logo mx-auto mb-4"
                             style="width: 200px;"/>
                        <p class="kad-kicker">Message received</p>
                        <h1 class="mb-3">Thank you for contacting KAD</h1>
                        <p class="mb-4" style="color: var(--kad-muted);">
                            Our team will get back to you shortly about your import, export,
                            sourcing, or partnership inquiry.
                        </p>
                        <a href="/" class="kad-btn kad-btn--primary">Back to Home</a>
                    </div>
                </section>
            </div>
        </t>
    </template>
</odoo>
