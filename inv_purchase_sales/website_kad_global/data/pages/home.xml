<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="0">
    <record id="website.homepage" model="ir.ui.view">
        <field name="active" eval="False"/>
    </record>

    <record id="page_home" model="website.page">
        <field name="name">Home</field>
        <field name="is_published" eval="True"/>
        <field name="key">website_kad_global.page_home</field>
        <field name="url">/</field>
        <field name="type">qweb</field>
        <field name="website_indexed" eval="True"/>
        <field name="arch" type="xml">
            <t t-name="website_kad_global.page_home">
                <t t-call="website.layout">
                    <t t-set="additional_title">KAD Import &amp; Export | Bridging Markets, Connecting Worlds</t>
                    <div id="wrap" class="oe_structure kad-site">
                        <t t-call="website_kad_global.homepage_body"/>
                    </div>
                </t>
            </t>
        </field>
    </record>
</odoo>
