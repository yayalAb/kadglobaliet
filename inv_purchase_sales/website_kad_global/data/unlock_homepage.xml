<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Clear noupdate on existing installs so homepage can refresh -->
        <function model="ir.model.data" name="write">
            <value model="ir.model.data" search="[('module', '=', 'website_kad_global'), ('name', '=', 'page_home')]"/>
            <value eval="{'noupdate': False}"/>
        </function>
    </data>
</odoo>
