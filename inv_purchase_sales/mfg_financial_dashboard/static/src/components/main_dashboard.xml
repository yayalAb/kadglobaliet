<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="mfg_financial_dashboard.MainDashboard" owl="1">
        <div class="container-fluid mfg-dashboard-scroll-root mfg-dashboard-page" t-ref="dashboardRoot">
            <div class="mfg-dashboard-scroll-pane" t-ref="dashboardInner">
                <div class="row m-0">
                    <div class="col-12">
                        <div class="mfg-dashboard-filter-bar">
                            <div class="mfg-dashboard-filter-bar__inner">
                                <div class="mfg-dashboard-header-block">
                                    <h1 class="mfg-dashboard-header-title">Executive Dashboard</h1>
                                </div>
                                <div class="mfg-dashboard-filter-controls">
                                    <div class="mfg-dashboard-filter-group mfg-dashboard-filter-group--range">
                                        <select class="form-select mfg-dashboard-filter-select"
                                                t-att-value="state.date_range"
                                                t-on-change="onDateRangeChange">
                                            <option t-foreach="dateRangeOptions" t-as="opt" t-key="opt.value"
                                                    t-att-value="opt.value"
                                                    t-att-selected="state.date_range === opt.value ? 'selected' : false"
                                                    t-esc="opt.label"/>
                                        </select>
                                    </div>
                                    <div class="mfg-dashboard-filter-group mfg-dashboard-filter-group--dates"
                                         t-att-class="state.date_range === 'custom' ? '' : 'mfg-dashboard-filter-group--dates-readonly'">
                                        <div class="mfg-dashboard-filter-input">
                                            <i class="fa fa-calendar-o mfg-dashboard-filter-input__icon"/>
                                            <input type="date" class="mfg-dashboard-filter-input__control"
                                                   t-att-value="state.start_date"
                                                   t-att-readonly="state.date_range !== 'custom' ? 'readonly' : false"
                                                   t-on-change="onStartDateChange"/>
                                        </div>
                                        <span class="mfg-dashboard-filter-sep">to</span>
                                        <div class="mfg-dashboard-filter-input">
                                            <i class="fa fa-calendar-o mfg-dashboard-filter-input__icon"/>
                                            <input type="date" class="mfg-dashboard-filter-input__control"
                                                   t-att-value="state.end_date"
                                                   t-att-readonly="state.date_range !== 'custom' ? 'readonly' : false"
                                                   t-on-change="onEndDateChange"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div t-if="state.loading" class="text-center py-5 text-muted">
                            <i class="fa fa-spinner fa-spin fa-2x"/>
                            <p class="mt-2">Loading dashboard…</p>
                        </div>

                        <t t-else="">
                            <div class="mfg-dashboard-body">
                            <div class="mfg-dashboard-overview">
                                <div class="mfg-dashboard-metrics-row mfg-dashboard-metrics-row--5">
                                    <DashboardCard name="'Total Purchase Value'" iconClass="'fa-money'"
                                        displayValue="formatCompactMoney(state.kpis.total_purchase_value)"
                                        onClick="openPurchaseOrders"/>
                                    <DashboardCard name="'Total Production Cost'" iconClass="'fa-industry'"
                                        displayValue="formatCompactMoney(state.kpis.total_production_cost)"
                                        onClick="openManufacturing"/>
                                    <DashboardCard name="'Total Sales Revenue'" iconClass="'fa-line-chart'"
                                        displayValue="formatCompactMoney(state.kpis.total_sales_revenue)"
                                        onClick="openSales"/>
                                    <DashboardCard name="'Finished Goods Stock (ETB)'" iconClass="'fa-cubes'"
                                        displayValue="formatCompactMoney(state.kpis.finished_goods_stock_value)"
                                        onClick="openStock"/>
                                    <DashboardCard name="'Raw Material Stock (ETB)'" iconClass="'fa-leaf'"
                                        displayValue="formatCompactMoney(state.kpis.raw_material_stock_value)"
                                        onClick="openStock"/>
                                </div>
                                <div class="mfg-dashboard-metrics-row mfg-dashboard-metrics-row--5">
                                    <DashboardCard name="'Packaging Material Stock (ETB)'" iconClass="'fa-archive'"
                                        displayValue="formatCompactMoney(state.kpis.packaging_stock_value)"
                                        onClick="openStock"/>
                                    <DashboardCard name="'Spare Part Inventory (ETB)'" iconClass="'fa-wrench'"
                                        displayValue="formatCompactMoney(state.kpis.spare_part_stock_value)"
                                        onClick="openStock"/>
                                    <DashboardCard t-if="workflowKpi('service_requests').available"
                                        name="'Service Requests'" iconClass="'fa-clipboard'"
                                        displayValue="workflowCount('service_requests')"
                                        onClick="openServiceRequests"/>
                                    <DashboardCard t-if="workflowKpi('sales_agreements').available"
                                        name="'Sales Agreements'" iconClass="'fa-file-text-o'"
                                        displayValue="workflowCount('sales_agreements')"
                                        onClick="openSalesAgreements"/>
                                    <DashboardCard t-if="workflowKpi('purchase_agreements').available"
                                        name="'Purchase Agreements'" iconClass="'fa-shopping-cart'"
                                        displayValue="workflowCount('purchase_agreements')"
                                        onClick="openPurchaseAgreements"/>
                                </div>
                            </div>

                            <!-- Charts row -->
                            <div class="row mfg-dashboard-row mfg-dashboard-row--3 mfg-dashboard-charts-row">
                                <div class="col-lg-4 col-md-12 d-flex">
                                    <div class="mfg-dashboard-section mfg-dashboard-chart-card">
                                        <h3 class="mfg-dashboard-section__title mb-0">Executive KPI Overview</h3>
                                        <div class="mfg-dashboard-chart-body">
                                            <ChartRenderer type="'bar'" title="'Executive KPIs (ETB)'"
                                                y_title="'Amount (ETB)'" x_title="'Metric'"
                                                data="state.charts.kpi_overview"/>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-4 col-md-12 d-flex">
                                    <div class="mfg-dashboard-section mfg-dashboard-chart-card">
                                        <h3 class="mfg-dashboard-section__title mb-0">Customer Outstanding</h3>
                                        <div class="mfg-dashboard-chart-body">
                                            <ChartRenderer type="'doughnut'" title="'Collection Balance'"
                                                data="state.charts.collection_outstanding"/>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-lg-4 col-md-12 d-flex">
                                    <div class="mfg-dashboard-section mfg-dashboard-chart-card">
                                        <h3 class="mfg-dashboard-section__title mb-0">Gross Profit by Product</h3>
                                        <div class="mfg-dashboard-chart-body">
                                            <ChartRenderer type="'bar'" title="'Profitability'"
                                                y_title="'Gross Profit (ETB)'" x_title="'Product'"
                                                data="state.charts.profitability"/>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- 1. Procurement -->
                            <div class="mfg-dashboard-section">
                                <h3 class="mfg-dashboard-section__title">1. Procurement &amp; Vendor Liability Dashboard</h3>
                                <p class="mfg-dashboard-section__subtitle">Purchase Order vs GRN vs Supplier Payment (selected period)</p>
                                <div class="mfg-dashboard-table-wrap">
                                    <table class="table mfg-dashboard-table">
                                        <thead>
                                            <tr>
                                                <th>PO No</th><th>Supplier</th><th>PO Amount</th>
                                                <th>GRN Amount</th><th>Bill Amount</th><th>Paid</th>
                                                <th>Remaining</th><th>Status</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr t-foreach="paginatedRows('procurement')" t-as="row" t-key="row.po_no">
                                                <td t-esc="row.po_no"/>
                                                <td t-esc="row.supplier"/>
                                                <td t-esc="formatMoney(row.po_amount)"/>
                                                <td t-esc="formatMoney(row.grn_amount)"/>
                                                <td t-esc="formatMoney(row.bill_amount)"/>
                                                <td t-esc="formatMoney(row.paid_amount)"/>
                                                <td t-esc="formatMoney(row.remaining)"/>
                                                <td><span t-att-class="statusBadgeClass(row.payment_status)" t-esc="row.payment_status"/></td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                                <PaginationControls
                                    page="currentPage('procurement')"
                                    totalPages="totalPages('procurement')"
                                    totalItems="totalItems('procurement')"
                                    pageSize="10"
                                    onPageChange="(page) => this.onTablePageChange('procurement', page)"/>
                            </div>

                            <!-- 2. Manufacturing -->
                            <div class="row mfg-dashboard-row mfg-dashboard-row--2">
                                <div class="col-lg-6">
                                    <div class="mfg-dashboard-section">
                                        <h3 class="mfg-dashboard-section__title">2. Production Efficiency Report</h3>
                                        <div class="mfg-dashboard-table-wrap">
                                            <table class="table mfg-dashboard-table">
                                                <thead>
                                                    <tr>
                                                        <th>MO No</th><th>Product</th><th>MO Qty</th>
                                                        <th>Actual Qty</th><th>Efficiency %</th><th>Status</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <tr t-foreach="paginatedRows('production_efficiency')" t-as="row" t-key="row.mo_no">
                                                        <td t-esc="row.mo_no"/>
                                                        <td t-esc="row.product"/>
                                                        <td t-esc="row.mo_qty"/>
                                                        <td t-esc="row.actual_qty"/>
                                                        <td t-esc="row.efficiency_pct + '%'"/>
                                                        <td t-esc="row.status"/>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>
                                        <PaginationControls
                                            page="currentPage('production_efficiency')"
                                            totalPages="totalPages('production_efficiency')"
                                            totalItems="totalItems('production_efficiency')"
                                            pageSize="10"
                                            onPageChange="(page) => this.onTablePageChange('production_efficiency', page)"/>
                                    </div>
                                </div>
                                <div class="col-lg-6">
                                    <div class="mfg-dashboard-section">
                                        <h3 class="mfg-dashboard-section__title">RM &amp; PM Consumption Analysis</h3>
                                        <div class="mfg-dashboard-table-wrap">
                                            <table class="table mfg-dashboard-table">
                                                <thead>
                                                    <tr>
                                                        <th>Material</th><th>MO No</th><th>Planned</th><th>Actual</th>
                                                        <th>Variance</th><th>Cost Impact</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <tr t-foreach="paginatedRows('rm_pm_consumption')" t-as="row" t-key="row_index">
                                                        <td t-esc="row.product"/>
                                                        <td t-esc="row.mo_no"/>
                                                        <td t-esc="row.planned"/>
                                                        <td t-esc="row.actual"/>
                                                        <td t-esc="row.variance"/>
                                                        <td t-esc="formatMoney(row.cost_impact)"/>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>
                                        <PaginationControls
                                            page="currentPage('rm_pm_consumption')"
                                            totalPages="totalPages('rm_pm_consumption')"
                                            totalItems="totalItems('rm_pm_consumption')"
                                            pageSize="10"
                                            onPageChange="(page) => this.onTablePageChange('rm_pm_consumption', page)"/>
                                    </div>
                                </div>
                            </div>

                            <div class="mfg-dashboard-section">
                                <h3 class="mfg-dashboard-section__title">By-Product Recovery Report</h3>
                                <div class="mfg-dashboard-table-wrap">
                                    <table class="table mfg-dashboard-table">
                                        <thead>
                                            <tr>
                                                <th>Product</th><th>By-product</th><th>Qty</th><th>Estimated Value</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr t-foreach="paginatedRows('byproduct_recovery')" t-as="row" t-key="row_index">
                                                <td t-esc="row.product"/>
                                                <td t-esc="row.byproduct"/>
                                                <td t-esc="row.qty"/>
                                                <td t-esc="formatMoney(row.estimated_value)"/>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                                <PaginationControls
                                    page="currentPage('byproduct_recovery')"
                                    totalPages="totalPages('byproduct_recovery')"
                                    totalItems="totalItems('byproduct_recovery')"
                                    pageSize="10"
                                    onPageChange="(page) => this.onTablePageChange('byproduct_recovery', page)"/>
                            </div>

                            <!-- 3. FG Stock -->
                            <div class="mfg-dashboard-section">
                                <h3 class="mfg-dashboard-section__title">3. Finished Goods (FG) Stock Dashboard</h3>
                                <p class="mfg-dashboard-section__subtitle">Opening Stock = stock at period start; Produced/የተበጠረ and Sold/Delivered reflect manufacturing output and customer deliveries in the selected period.</p>
                                <div class="mfg-dashboard-table-wrap">
                                    <table class="table mfg-dashboard-table">
                                        <thead>
                                            <tr>
                                                <th>Product</th>
                                                <th title="Quantity on hand at the start of the selected period">Opening Stock</th>
                                                <th>Produced/የተበጠረ</th>
                                                <th>Sold/Delivered</th>
                                                <th>Ending</th>
                                                <th>Stock Value (ETB)</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr t-foreach="paginatedRows('fg_inventory')" t-as="row" t-key="row.product">
                                                <td t-esc="row.product"/>
                                                <td t-esc="row.opening"/>
                                                <td t-esc="row.produced"/>
                                                <td t-esc="row.sold"/>
                                                <td t-esc="row.ending"/>
                                                <td t-esc="formatMoney(row.stock_value)"/>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                                <PaginationControls
                                    page="currentPage('fg_inventory')"
                                    totalPages="totalPages('fg_inventory')"
                                    totalItems="totalItems('fg_inventory')"
                                    pageSize="10"
                                    onPageChange="(page) => this.onTablePageChange('fg_inventory', page)"/>
                            </div>

                            <!-- 4 & 5 Raw + Packaging -->
                            <div class="row mfg-dashboard-row mfg-dashboard-row--2">
                                <div class="col-lg-6">
                                    <div class="mfg-dashboard-section">
                                        <h3 class="mfg-dashboard-section__title">4. Raw Material Stock Report</h3>
                                        <div class="mfg-dashboard-table-wrap">
                                            <table class="table mfg-dashboard-table">
                                                <thead>
                                                    <tr>
                                                        <th>Material</th><th>Available</th><th>Reserved</th>
                                                        <th>Free Stock</th><th>Value (ETB)</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <tr t-foreach="paginatedRows('raw_material_stock')" t-as="row" t-key="row.material">
                                                        <td t-esc="row.material"/>
                                                        <td t-esc="row.available"/>
                                                        <td t-esc="row.reserved"/>
                                                        <td t-esc="row.free_stock"/>
                                                        <td t-esc="formatMoney(row.stock_value)"/>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>
                                        <PaginationControls
                                            page="currentPage('raw_material_stock')"
                                            totalPages="totalPages('raw_material_stock')"
                                            totalItems="totalItems('raw_material_stock')"
                                            pageSize="10"
                                            onPageChange="(page) => this.onTablePageChange('raw_material_stock', page)"/>
                                    </div>
                                </div>
                                <div class="col-lg-6">
                                    <div class="mfg-dashboard-section">
                                        <h3 class="mfg-dashboard-section__title">5. Packaging Material Stock Report</h3>
                                        <div class="mfg-dashboard-table-wrap">
                                            <table class="table mfg-dashboard-table">
                                                <thead>
                                                    <tr>
                                                        <th>Material</th><th>Available</th><th>Consumption</th>
                                                        <th>Remaining</th><th>Value (ETB)</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <tr t-foreach="paginatedRows('packaging_stock')" t-as="row" t-key="row.material">
                                                        <td t-esc="row.material"/>
                                                        <td t-esc="row.available"/>
                                                        <td t-esc="row.consumption"/>
                                                        <td t-esc="row.remaining"/>
                                                        <td t-esc="formatMoney(row.stock_value)"/>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>
                                        <PaginationControls
                                            page="currentPage('packaging_stock')"
                                            totalPages="totalPages('packaging_stock')"
                                            totalItems="totalItems('packaging_stock')"
                                            pageSize="10"
                                            onPageChange="(page) => this.onTablePageChange('packaging_stock', page)"/>
                                    </div>
                                </div>
                            </div>

                            <!-- 6 Spare parts -->
                            <div class="mfg-dashboard-section">
                                <h3 class="mfg-dashboard-section__title">6. Spare Part Inventory Dashboard</h3>
                                <div class="mfg-dashboard-table-wrap">
                                    <table class="table mfg-dashboard-table">
                                        <thead>
                                            <tr>
                                                <th>Spare Part</th><th>Available</th>
                                                <th>Status</th><th>Value (ETB)</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr t-foreach="paginatedRows('spare_parts')" t-as="row" t-key="row.part">
                                                <td t-esc="row.part"/>
                                                <td t-esc="row.available"/>
                                                <td><span t-att-class="statusBadgeClass(row.status)" t-esc="row.status"/></td>
                                                <td t-esc="formatMoney(row.stock_value)"/>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                                <PaginationControls
                                    page="currentPage('spare_parts')"
                                    totalPages="totalPages('spare_parts')"
                                    totalItems="totalItems('spare_parts')"
                                    pageSize="10"
                                    onPageChange="(page) => this.onTablePageChange('spare_parts', page)"/>
                            </div>

                            <!-- 7 & 8 Delivery + Collections -->
                            <div class="row mfg-dashboard-row mfg-dashboard-row--2">
                                <div class="col-lg-6">
                                    <div class="mfg-dashboard-section">
                                        <h3 class="mfg-dashboard-section__title">7. Delivery &amp; Sales Dashboard</h3>
                                        <p class="mfg-dashboard-section__subtitle">Delivery Order vs Sales Invoice (service vetting reference shown when linked to a service request)</p>
                                        <div class="mfg-dashboard-table-wrap">
                                            <table class="table mfg-dashboard-table">
                                                <thead>
                                                    <tr>
                                                        <th>DO No</th><th>Customer</th><th>Product</th>
                                                        <th>Service</th><th>Delivered</th><th>Invoiced</th><th>Status</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <tr t-foreach="paginatedRows('delivery_sales')" t-as="row" t-key="row.do_no">
                                                        <td t-esc="row.do_no"/>
                                                        <td t-esc="row.customer"/>
                                                        <td t-esc="row.product"/>
                                                        <td t-esc="row.service"/>
                                                        <td t-esc="row.delivered_qty"/>
                                                        <td t-esc="row.invoiced_qty"/>
                                                        <td t-esc="row.delivery_status"/>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>
                                        <PaginationControls
                                            page="currentPage('delivery_sales')"
                                            totalPages="totalPages('delivery_sales')"
                                            totalItems="totalItems('delivery_sales')"
                                            pageSize="10"
                                            onPageChange="(page) => this.onTablePageChange('delivery_sales', page)"/>
                                    </div>
                                </div>
                                <div class="col-lg-6">
                                    <div class="mfg-dashboard-section">
                                        <h3 class="mfg-dashboard-section__title">8. Customer Payment Collection</h3>
                                        <div class="mfg-dashboard-table-wrap">
                                            <table class="table mfg-dashboard-table">
                                                <thead>
                                                    <tr>
                                                        <th>Customer</th><th>Invoice</th><th>Collected</th>
                                                        <th>Balance</th><th>Status</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    <tr t-foreach="paginatedRows('customer_collections')" t-as="row" t-key="row.customer">
                                                        <td t-esc="row.customer"/>
                                                        <td t-esc="formatMoney(row.invoice_amount)"/>
                                                        <td t-esc="formatMoney(row.collected_amount)"/>
                                                        <td t-esc="formatMoney(row.remaining)"/>
                                                        <td><span t-att-class="statusBadgeClass(row.collection_status)" t-esc="row.collection_status"/></td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>
                                        <PaginationControls
                                            page="currentPage('customer_collections')"
                                            totalPages="totalPages('customer_collections')"
                                            totalItems="totalItems('customer_collections')"
                                            pageSize="10"
                                            onPageChange="(page) => this.onTablePageChange('customer_collections', page)"/>
                                    </div>
                                </div>
                            </div>

                            <!-- 9 Partner Ledger -->
                            <div class="mfg-dashboard-section mfg-dashboard-section--partner-ledger">
                                <div class="mfg-dashboard-section__head">
                                    <div class="mfg-dashboard-section__head-text">
                                        <h3 class="mfg-dashboard-section__title mb-0">9. Partner Ledger Report</h3>
                                        <p class="mfg-dashboard-section__subtitle mb-0">Posted receivable &amp; payable entries by partner</p>
                                    </div>
                                    <div class="mfg-dashboard-partner-filter">
                                        <label class="mfg-dashboard-partner-filter__label" for="mfg_partner_ledger_select">Partner</label>
                                        <select id="mfg_partner_ledger_select"
                                                class="form-select form-select-sm mfg-dashboard-partner-filter__select"
                                                t-att-value="partnerFilterDropdownValue()"
                                                t-on-change="onPartnerFilterSelect">
                                            <option value="">All partners</option>
                                            <option t-foreach="state.partner_ledger_partner_totals" t-as="pt" t-key="pt.partner_id"
                                                    t-att-value="pt.partner_id"
                                                    t-esc="pt.partner"/>
                                        </select>
                                    </div>
                                </div>

                                <div class="mfg-dashboard-table-wrap">
                                    <table class="table mfg-dashboard-table">
                                        <thead>
                                            <tr>
                                                <th>Date</th><th>Partner</th><th>Account</th><th>Type</th>
                                                <th>Journal Entry</th><th>Label</th>
                                                <th class="text-end">Debit</th><th class="text-end">Credit</th><th class="text-end">Balance</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr t-foreach="paginatedRows('partner_ledger')" t-as="row" t-key="partnerLedgerRowKey(row, row_index)"
                                                t-att-class="{
                                                    'mfg-dashboard-table__partner-total': row.row_type === 'partner_total',
                                                    'mfg-dashboard-table__grand-total': row.row_type === 'grand_total',
                                                }">
                                                <t t-if="row.row_type === 'line'">
                                                    <td t-esc="row.date"/>
                                                    <td t-esc="row.partner"/>
                                                    <td t-esc="row.account"/>
                                                    <td t-esc="row.account_type"/>
                                                    <td t-esc="row.move"/>
                                                    <td t-esc="row.label"/>
                                                    <td class="text-end" t-esc="formatMoney(row.debit_raw !== undefined ? row.debit_raw : row.debit)"/>
                                                    <td class="text-end" t-esc="formatMoney(row.credit_raw !== undefined ? row.credit_raw : row.credit)"/>
                                                    <td class="text-end" t-esc="formatMoney(row.balance_raw !== undefined ? row.balance_raw : row.balance)"/>
                                                </t>
                                                <t t-elif="row.row_type === 'partner_total'">
                                                    <td/>
                                                    <td colspan="5"><strong t-esc="row.partner + ' — Total'"/></td>
                                                    <td class="text-end"><strong t-esc="formatMoney(row.debit_raw)"/></td>
                                                    <td class="text-end"><strong t-esc="formatMoney(row.credit_raw)"/></td>
                                                    <td class="text-end"><strong t-esc="formatMoney(row.balance_raw)"/></td>
                                                </t>
                                                <t t-else="">
                                                    <td/>
                                                    <td colspan="5"><strong t-esc="row.partner"/></td>
                                                    <td class="text-end"><strong t-esc="formatMoney(row.debit_raw)"/></td>
                                                    <td class="text-end"><strong t-esc="formatMoney(row.credit_raw)"/></td>
                                                    <td class="text-end"><strong t-esc="formatMoney(row.balance_raw)"/></td>
                                                </t>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>

                                <PaginationControls
                                    page="currentPage('partner_ledger')"
                                    totalPages="totalPages('partner_ledger')"
                                    totalItems="totalItems('partner_ledger')"
                                    pageSize="10"
                                    onPageChange="(page) => this.onTablePageChange('partner_ledger', page)"/>
                            </div>

                            <!-- 10 Profitability -->
                            <div class="mfg-dashboard-section">
                                <h3 class="mfg-dashboard-section__title">10. Profitability Dashboard</h3>
                                <div class="mfg-dashboard-table-wrap">
                                    <table class="table mfg-dashboard-table">
                                        <thead>
                                            <tr>
                                                <th>Product</th><th>Revenue</th><th>Production Cost</th>
                                                <th>Gross Profit</th><th>Margin %</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr t-foreach="paginatedRows('profitability')" t-as="row" t-key="row.product">
                                                <td t-esc="row.product"/>
                                                <td t-esc="formatMoney(row.revenue)"/>
                                                <td t-esc="formatMoney(row.production_cost)"/>
                                                <td t-esc="formatMoney(row.gross_profit)"/>
                                                <td t-esc="row.profit_margin + '%'"/>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                                <PaginationControls
                                    page="currentPage('profitability')"
                                    totalPages="totalPages('profitability')"
                                    totalItems="totalItems('profitability')"
                                    pageSize="10"
                                    onPageChange="(page) => this.onTablePageChange('profitability', page)"/>
                            </div>

                            <!-- 11 Stock Movement -->
                            <div class="mfg-dashboard-section">
                                <h3 class="mfg-dashboard-section__title">Stock Movement</h3>
                                <p class="mfg-dashboard-section__subtitle">
                                    Product quantities in and out by warehouse for the selected period
                                </p>
                                <div class="mfg-dashboard-table-wrap">
                                    <table class="table mfg-dashboard-table">
                                        <thead>
                                            <tr>
                                                <th>Product</th>
                                                <th>Product Reference</th>
                                                <th>Warehouse</th>
                                                <th class="text-end">Total In</th>
                                                <th class="text-end">Total Out</th>
                                                <th class="text-end">Balance</th>
                                                <th class="text-center">Detail</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <tr t-foreach="paginatedRows('stock_movement')" t-as="sm" t-key="sm.id">
                                                <td t-esc="sm.product"/>
                                                <td t-esc="sm.product_reference"/>
                                                <td t-esc="sm.warehouse"/>
                                                <td class="text-end mfg-dashboard-qty--positive" t-esc="formatQty(sm.total_in)"/>
                                                <td class="text-end mfg-dashboard-qty--negative" t-esc="formatQty(sm.total_out)"/>
                                                <td t-att-class="'text-end ' + balanceClass(sm.balance)" t-esc="formatQty(sm.balance)"/>
                                                <td class="text-center">
                                                    <button type="button"
                                                        class="btn btn-sm mfg-dashboard-detail-btn"
                                                        t-on-click="() => this.openStockMovementDetail(sm)">
                                                        Detail
                                                    </button>
                                                </td>
                                            </tr>
                                            <tr t-if="!state.stock_movements.length">
                                                <td colspan="7" class="text-center text-muted py-4">
                                                    No stock movements in this period
                                                </td>
                                            </tr>
                                            <tr t-if="state.stock_movements.length"
                                                class="mfg-dashboard-table__summary-total">
                                                <td colspan="3">
                                                    <strong>Summary</strong>
                                                    <span class="mfg-dashboard-summary-meta">
                                                        (<t t-esc="state.stock_movement_summary.product_count"/> products,
                                                        <t t-esc="state.stock_movement_summary.row_count"/> lines)
                                                    </span>
                                                </td>
                                                <td class="text-end">
                                                    <strong class="mfg-dashboard-qty--positive"
                                                        t-esc="formatQty(state.stock_movement_summary.total_in)"/>
                                                </td>
                                                <td class="text-end">
                                                    <strong class="mfg-dashboard-qty--negative"
                                                        t-esc="formatQty(state.stock_movement_summary.total_out)"/>
                                                </td>
                                                <td class="text-end">
                                                    <strong t-att-class="balanceClass(state.stock_movement_summary.balance)"
                                                        t-esc="formatQty(state.stock_movement_summary.balance)"/>
                                                </td>
                                                <td/>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                                <PaginationControls
                                    page="currentPage('stock_movement')"
                                    totalPages="totalPages('stock_movement')"
                                    totalItems="totalItems('stock_movement')"
                                    pageSize="10"
                                    onPageChange="(page) => this.onTablePageChange('stock_movement', page)"/>
                            </div>
                            </div>
                        </t>
                    </div>
                </div>
            </div>
        </div>
    </t>
</templates>
