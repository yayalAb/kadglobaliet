<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_export_order_kanban" model="ir.ui.view">
        <field name="name">export.export.order.kanban</field>
        <field name="model">export.export.order</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="state"/>
                <field name="color"/>
                <field name="export_payment_method"/>
                <field name="amount_total"/>
                <field name="currency_id"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_record_top mb-2">
                                <strong class="o_kanban_record_title"><field name="name"/></strong>
                            </div>
                            <field name="partner_id"/>
                            <div class="text-muted">
                                <field name="sale_order_id"/>
                            </div>
                            <div class="mt-2">
                                <field name="export_payment_method" widget="badge" optional="hide"/>
                                <span class="float-end fw-bold">
                                    <field name="amount_total" widget="monetary"/>
                                </span>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_export_order_list" model="ir.ui.view">
        <field name="name">export.export.order.list</field>
        <field name="model">export.export.order</field>
        <field name="arch" type="xml">
            <list string="Export Orders">
                <field name="name"/>
                <field name="sale_order_id"/>
                <field name="partner_id"/>
                <field name="export_payment_method"/>
                <field name="state" widget="badge"/>
                <field name="quotation_state" optional="show"/>
                <field name="amount_total"/>
                <field name="user_id" widget="many2one_avatar_user" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_export_order_form" model="ir.ui.view">
        <field name="name">export.export.order.form</field>
        <field name="model">export.export.order</field>
        <field name="arch" type="xml">
            <form string="Export Order">
                <header>
                    <field name="state" widget="statusbar"
                        statusbar_visible="quotation,contract,sample_approval,bag_mark,payment_setup,payment_process,shipping_instruction,booking,inspection,shipment,documentation,payment_collection,nbe_settlement,completed"/>

                    <!-- Quotation -->
                    <button name="action_send_quotation" string="Send Quotation" type="object"
                        invisible="state != 'quotation' or quotation_state != 'draft'"/>
                    <button name="action_accept_quotation" string="Accept" type="object" class="oe_highlight"
                        invisible="state != 'quotation'"/>
                    <button name="action_reject_quotation" string="Reject" type="object"
                        invisible="state != 'quotation'"/>

                    <!-- Contract -->
                    <button name="action_prepare_contract" string="Prepare Contract" type="object"
                        invisible="state != 'contract'"/>
                    <button name="action_contract_complete" string="Contract Signed" type="object" class="oe_highlight"
                        invisible="state != 'contract'"/>

                    <!-- Payment -->
                    <button name="action_confirm_payment_setup" string="Confirm Payment Method" type="object" class="oe_highlight"
                        invisible="state != 'payment_setup'"/>
                    <button name="action_create_invoice" string="Create Invoice" type="object"
                        invisible="state not in ('payment_process', 'payment_collection')"/>
                    <button name="action_view_payments" string="Register Payment" type="object"
                        invisible="state not in ('payment_process', 'payment_collection')"/>
                    <button name="action_validate_payment_process" string="Validate Payment" type="object" class="oe_highlight"
                        invisible="state != 'payment_process'"/>

                    <!-- Logistics -->
                    <button name="action_confirm_shipping_instruction" string="Confirm Shipping Instruction" type="object" class="oe_highlight"
                        invisible="state != 'shipping_instruction'"/>
                    <button name="action_confirm_booking" string="Confirm Booking" type="object" class="oe_highlight"
                        invisible="state != 'booking'"/>
                    <button name="action_pass_inspection" string="Inspection Passed" type="object" class="oe_highlight"
                        invisible="state != 'inspection'"/>
                    <button name="action_fail_inspection" string="Inspection Failed" type="object"
                        invisible="state != 'inspection'"/>
                    <button name="action_create_delivery" string="Link Deliveries" type="object"
                        invisible="state != 'shipment'"/>
                    <button name="action_confirm_shipment" string="Confirm Shipment" type="object" class="oe_highlight"
                        invisible="state != 'shipment'"/>
                    <button name="action_send_shipment_status" string="Notify Customer" type="object"
                        invisible="state not in ('shipment', 'documentation')"/>

                    <!-- Close -->
                    <button name="action_confirm_documentation" string="Documents Approved" type="object" class="oe_highlight"
                        invisible="state != 'documentation'"/>
                    <button name="action_confirm_final_payment" string="Final Payment Done" type="object" class="oe_highlight"
                        invisible="state != 'payment_collection'"/>
                    <button name="action_complete_nbe" string="Complete" type="object" class="oe_highlight"
                        invisible="state != 'nbe_settlement'"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_sale_order" type="object" class="oe_stat_button" icon="fa-usd">
                            <div class="o_stat_info"><span class="o_stat_text">Quotation</span></div>
                        </button>
                        <button name="action_view_contract" type="object" class="oe_stat_button" icon="fa-file-text-o"
                            invisible="not contract_id">
                            <div class="o_stat_info"><span class="o_stat_text">Contract</span></div>
                        </button>
                        <button name="action_view_sample_approval" type="object" class="oe_stat_button" icon="fa-flask"
                            invisible="not sample_approval_id">
                            <div class="o_stat_info"><span class="o_stat_text">Sample</span></div>
                        </button>
                        <button name="action_view_bag_mark" type="object" class="oe_stat_button" icon="fa-tag"
                            invisible="not bag_mark_id">
                            <div class="o_stat_info"><span class="o_stat_text">Bag Mark</span></div>
                        </button>
                        <button name="action_view_lc" type="object" class="oe_stat_button" icon="fa-bank"
                            invisible="not lc_id">
                            <div class="o_stat_info"><span class="o_stat_text">LC</span></div>
                        </button>
                        <button name="action_view_cad" type="object" class="oe_stat_button" icon="fa-money"
                            invisible="not cad_id">
                            <div class="o_stat_info"><span class="o_stat_text">CAD</span></div>
                        </button>
                        <button name="action_view_shipping_instruction" type="object" class="oe_stat_button" icon="fa-anchor"
                            invisible="not shipping_instruction_id">
                            <div class="o_stat_info"><span class="o_stat_text">Shipping</span></div>
                        </button>
                        <button name="action_view_booking" type="object" class="oe_stat_button" icon="fa-ship"
                            invisible="not booking_id">
                            <div class="o_stat_info"><span class="o_stat_text">Booking</span></div>
                        </button>
                        <button name="action_view_shipment_document" type="object" class="oe_stat_button" icon="fa-folder-open"
                            invisible="not shipment_document_id">
                            <div class="o_stat_info"><span class="o_stat_text">Documents</span></div>
                        </button>
                        <button name="action_view_nbe_settlement" type="object" class="oe_stat_button" icon="fa-institution"
                            invisible="not nbe_settlement_id">
                            <div class="o_stat_info"><span class="o_stat_text">NBE</span></div>
                        </button>
                        <button name="action_view_pickings" type="object" class="oe_stat_button" icon="fa-truck"
                            invisible="picking_count == 0">
                            <field name="picking_count" widget="statinfo" string="Deliveries"/>
                        </button>
                        <button name="action_view_invoices" type="object" class="oe_stat_button" icon="fa-pencil-square-o"
                            invisible="invoice_count == 0">
                            <field name="invoice_count" widget="statinfo" string="Invoices"/>
                        </button>
                        <button name="action_view_payments" type="object" class="oe_stat_button" icon="fa-credit-card">
                            <field name="payment_count" widget="statinfo" string="Payments"/>
                        </button>
                    </div>
                    <div class="oe_title"><h1><field name="name" readonly="1"/></h1></div>
                    <group>
                        <group string="Quotation">
                            <field name="sale_order_id" readonly="1"/>
                            <field name="partner_id"/>
                            <field name="quotation_state" readonly="1"/>
                            <field name="destination_country_id"/>
                            <field name="incoterm_id"/>
                            <field name="amount_total"/>
                        </group>
                        <group string="Payment Tracking">
                            <field name="export_payment_method"/>
                            <field name="amount_due"/>
                            <field name="amount_paid"/>
                            <field name="balance"/>
                            <field name="inspection_state" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes" name="notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_export_order_search" model="ir.ui.view">
        <field name="name">export.export.order.search</field>
        <field name="model">export.export.order</field>
        <field name="arch" type="xml">
            <search string="Export Orders">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="sale_order_id"/>
                <filter string="Quotation" name="quotation" domain="[('state', '=', 'quotation')]"/>
                <filter string="In Progress" name="in_progress"
                    domain="[('state', 'not in', ('completed', 'cancelled', 'quotation'))]"/>
                <filter string="Completed" name="completed" domain="[('state', '=', 'completed')]"/>
                <group expand="0" string="Group By">
                    <filter string="Stage" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Customer" name="group_partner" context="{'group_by': 'partner_id'}"/>
                    <filter string="Payment Method" name="group_payment" context="{'group_by': 'export_payment_method'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_export_order" model="ir.actions.act_window">
        <field name="name">Export Orders</field>
        <field name="res_model">export.export.order</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Start from a foreign Sales quotation</p>
            <p>Create a quotation in Sales, set scope to Foreign, then click <strong>Start Export Order</strong>.</p>
        </field>
    </record>

    <menuitem id="menu_export_order"
        name="Export Orders"
        parent="sale.sale_menu_root"
        action="action_export_order"
        sequence="10"/>

</odoo>
