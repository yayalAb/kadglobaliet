<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_currency_form_inherit_vendorbid_rates" model="ir.ui.view">
            <field name="name">res.currency.form.inherit.vendorbid.rates</field>
            <field name="model">res.currency</field>
            <field name="inherit_id" ref="base.view_currency_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='rate_ids']/list/field[@name='name']" position="after">
                    <field name="exchange_rate_bank_id"/>
                </xpath>
            </field>
        </record>

        <record id="view_currency_rate_tree_inherit_vendorbid" model="ir.ui.view">
            <field name="name">res.currency.rate.list.inherit.vendorbid</field>
            <field name="model">res.currency.rate</field>
            <field name="inherit_id" ref="base.view_currency_rate_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="after">
                    <field name="exchange_rate_bank_id"/>
                </xpath>
            </field>
        </record>

        <record id="view_currency_rate_form_inherit_vendorbid" model="ir.ui.view">
            <field name="name">res.currency.rate.form.inherit.vendorbid</field>
            <field name="model">res.currency.rate</field>
            <field name="inherit_id" ref="base.view_currency_rate_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="after">
                    <field name="exchange_rate_bank_id"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
