<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Customer Good Receiving Note: gross/tare/net from custom picking operation (+ GRN fallback) -->
    <template id="cgrn_document_custom_weights" inherit_id="stock_picking_grn_report.cgrn_document">
        <xpath expr="//table[@id='cgrn_item_table']/thead" position="replace">
            <thead>
                <tr>
                    <th style="width:4%;">S.N</th>
                    <th style="width:12%;">Item Code</th>
                    <th style="width:22%;">Item Description</th>
                    <th style="width:10%;">Unit of Measure</th>
                    <th style="width:8%;">ብዛት<br/>Quantity</th>
                    <th style="width:10%;">Gross weight<br/>ጠቅላላ ክብደት</th>
                    <th style="width:10%;">Tare weight<br/>ተር ሚዛን</th>
                    <th style="width:10%;">Net weight<br/>የተጣራ ክብደት</th>
                </tr>
            </thead>
        </xpath>
        <xpath expr="//table[@id='cgrn_item_table']/tbody" position="replace">
            <tbody>
                <t t-set="row" t-value="0"/>
                <t t-foreach="o._grn_good_receiving_report_moves()" t-as="move">
                    <t t-set="row" t-value="row + 1"/>
                    <tr>
                        <td class="cgrn-center"><span t-esc="row"/></td>
                        <td><span t-field="move.product_id.default_code"/></td>
                        <td><span t-field="move.product_id.name"/></td>
                        <td class="cgrn-center"><span t-field="move.product_uom"/></td>
                        <td class="cgrn-num"><span t-esc="'{0:,.4f}'.format(move.quantity or 0.0)"/></td>
                        <td class="cgrn-num">
                            <t t-if="move.customer_vetting_gross_weight or move.grn_gross_weight">
                                <span t-esc="'{0:,.4f}'.format(move.customer_vetting_gross_weight or move.grn_gross_weight or 0.0)"/>
                            </t>
                            <t t-else="">-</t>
                        </td>
                        <td class="cgrn-num">
                            <t t-if="move.customer_vetting_tare_weight or move.grn_tare_weight">
                                <span t-esc="'{0:,.4f}'.format(move.customer_vetting_tare_weight or move.grn_tare_weight or 0.0)"/>
                            </t>
                            <t t-else="">-</t>
                        </td>
                        <td class="cgrn-num">
                            <t t-if="move.customer_vetting_line_net_weight or move.customer_vetting_gross_weight or move.customer_vetting_tare_weight">
                                <span t-esc="'{0:,.4f}'.format(move.customer_vetting_line_net_weight or 0.0)"/>
                            </t>
                            <t t-elif="move.grn_net_weight and move.grn_net_weight != 0">
                                <span t-esc="'{0:,.4f}'.format(move.grn_net_weight)"/>
                            </t>
                            <t t-elif="move.grn_gross_weight or move.grn_tare_weight">
                                <span t-esc="'{0:,.4f}'.format((move.grn_gross_weight or 0.0) - (move.grn_tare_weight or 0.0))"/>
                            </t>
                            <t t-else="">-</t>
                        </td>
                    </tr>
                </t>
            </tbody>
        </xpath>
    </template>

    <!-- Good Receiving Attachment: add net column + custom weights -->
    <template id="gra_document_custom_weights" inherit_id="stock_picking_grn_report.gra_document">
        <xpath expr="//table[@id='gra_item_table']/thead" position="replace">
            <thead>
                <tr>
                    <th style="width:3%;">S.N</th>
                    <th style="width:8%;">Item Code</th>
                    <th style="width:14%;">Item Description</th>
                    <th style="width:7%;">Unit of<br/>Measure</th>
                    <th style="width:7%;">Demand</th>
                    <th style="width:7%;">Gross<br/>weight</th>
                    <th style="width:7%;">Tare<br/>weight</th>
                    <th style="width:7%;">Net<br/>weight</th>
                    <th style="width:9%;">የተረከበው ክብደት<br/>Received Qty</th>
                    <th style="width:8%;">Unit<br/>Price</th>
                    <th style="width:8%;">Total Unit<br/>Price</th>
                </tr>
            </thead>
        </xpath>
        <xpath expr="//table[@id='gra_item_table']/tbody" position="replace">
            <tbody>
                <t t-set="row" t-value="0"/>
                <t t-foreach="o.move_ids_without_package.filtered(lambda m: m.state != 'cancel')" t-as="move">
                    <t t-set="row" t-value="row + 1"/>
                    <t t-set="pu" t-value="move.purchase_line_id.price_unit if move.purchase_line_id else 0.0"/>
                    <t t-set="rqty" t-value="move.quantity or 0.0"/>
                    <t t-set="lt" t-value="rqty * pu"/>
                    <tr>
                        <td class="gra-center"><span t-esc="row"/></td>
                        <td><span t-field="move.product_id.default_code"/></td>
                        <td><span t-field="move.product_id.name"/></td>
                        <td class="gra-center"><span t-field="move.product_uom"/></td>
                        <td class="gra-num"><span t-esc="'{:,.2f}'.format(move.product_uom_qty or 0.0)"/></td>
                        <td class="gra-num">
                            <t t-if="move.customer_vetting_gross_weight or move.grn_gross_weight">
                                <span t-esc="'{:,.2f}'.format(move.customer_vetting_gross_weight or move.grn_gross_weight or 0.0)"/>
                            </t>
                            <t t-else="">-</t>
                        </td>
                        <td class="gra-num">
                            <t t-if="move.customer_vetting_tare_weight or move.grn_tare_weight">
                                <span t-esc="'{:,.2f}'.format(move.customer_vetting_tare_weight or move.grn_tare_weight or 0.0)"/>
                            </t>
                            <t t-else="">-</t>
                        </td>
                        <td class="gra-num">
                            <t t-if="move.customer_vetting_gross_weight or move.customer_vetting_tare_weight or move.customer_vetting_line_net_weight">
                                <span t-esc="'{:,.2f}'.format(move.customer_vetting_line_net_weight or 0.0)"/>
                            </t>
                            <t t-elif="move.grn_gross_weight or move.grn_tare_weight">
                                <span t-esc="'{:,.2f}'.format((move.grn_gross_weight or 0.0) - (move.grn_tare_weight or 0.0))"/>
                            </t>
                            <t t-else="">-</t>
                        </td>
                        <td class="gra-num"><span t-esc="'{:,.2f}'.format(rqty)"/></td>
                        <td class="gra-num">
                            <t t-if="move.purchase_line_id"><span t-esc="'{:,.2f}'.format(pu)"/></t>
                            <t t-else="">-</t>
                        </td>
                        <td class="gra-num">
                            <t t-if="move.purchase_line_id"><span t-esc="'{:,.2f}'.format(lt)"/></t>
                            <t t-else="">-</t>
                        </td>
                    </tr>
                </t>
            </tbody>
        </xpath>
    </template>

    <!-- Customer delivery note PDF: custom weights + GRN fallback -->
    <template id="report_customer_delivery_note_document_custom_weights" inherit_id="stock_picking_grn_report.report_customer_delivery_note_document">
        <xpath expr="//table[@id='cdn_item_table']/thead" position="replace">
            <thead style="background-color: #f0f0f0;">
                <tr>
                    <th style="border: 1px solid #000; padding: 4px 2px; text-align: center; width: 4%;">S.N</th>
                    <th style="border: 1px solid #000; padding: 4px 2px; text-align: center; width: 9%;">Item Code</th>
                    <th style="border: 1px solid #000; padding: 4px 2px; text-align: center; width: 24%;">Item Description</th>
                    <th style="border: 1px solid #000; padding: 4px 2px; text-align: center; width: 8%;">Unit of<br/>Measure</th>
                    <th style="border: 1px solid #000; padding: 4px 2px; text-align: center; width: 9%;">Quantity<br/><span style="font-weight: normal;">የደንብ ብዛት</span></th>
                    <th style="border: 1px solid #000; padding: 4px 2px; text-align: center; width: 10%;">Gross weight<br/><span style="font-weight: normal;">ጠቅላላ ክብደት</span></th>
                    <th style="border: 1px solid #000; padding: 4px 2px; text-align: center; width: 10%;">Tare weight<br/><span style="font-weight: normal;">ተር ሚዛን</span></th>
                    <th style="border: 1px solid #000; padding: 4px 2px; text-align: center; width: 10%;">Net weight<br/><span style="font-weight: normal;">የተጣራ ክብደት</span></th>
                </tr>
            </thead>
        </xpath>
        <xpath expr="//table[@id='cdn_item_table']/tbody" position="replace">
            <tbody>
                <t t-set="i" t-value="0"/>
                <t t-foreach="o.move_ids_without_package" t-as="move">
                    <t t-set="i" t-value="i + 1"/>
                    <tr>
                        <td style="border: 1px solid #000; padding: 3px; text-align: center;"><span t-esc="i"/></td>
                        <td style="border: 1px solid #000; padding: 3px;"><span t-field="move.product_id.default_code"/></td>
                        <td style="border: 1px solid #000; padding: 3px;"><span t-field="move.product_id.name"/></td>
                        <td style="border: 1px solid #000; padding: 3px; text-align: center;"><span t-field="move.product_uom.name"/></td>
                        <td style="border: 1px solid #000; padding: 3px; text-align: right;">
                            <span t-esc="'{0:,.2f}'.format(move.quantity)"/>
                        </td>
                        <td style="border: 1px solid #000; padding: 3px; text-align: right;">
                            <t t-if="move.customer_vetting_gross_weight or move.grn_gross_weight">
                                <span t-esc="'{0:,.2f}'.format(move.customer_vetting_gross_weight or move.grn_gross_weight or 0.0)"/>
                            </t>
                            <t t-else="">-</t>
                        </td>
                        <td style="border: 1px solid #000; padding: 3px; text-align: right;">
                            <t t-if="move.customer_vetting_tare_weight or move.grn_tare_weight">
                                <span t-esc="'{0:,.2f}'.format(move.customer_vetting_tare_weight or move.grn_tare_weight or 0.0)"/>
                            </t>
                            <t t-else="">-</t>
                        </td>
                        <td style="border: 1px solid #000; padding: 3px; text-align: right;">
                            <t t-if="move.customer_vetting_line_net_weight or move.customer_vetting_gross_weight or move.customer_vetting_tare_weight">
                                <span t-esc="'{0:,.2f}'.format(move.customer_vetting_line_net_weight or 0.0)"/>
                            </t>
                            <t t-elif="move.grn_net_weight and move.grn_net_weight != 0">
                                <span t-esc="'{0:,.2f}'.format(move.grn_net_weight)"/>
                            </t>
                            <t t-elif="move.grn_gross_weight or move.grn_tare_weight">
                                <span t-esc="'{0:,.2f}'.format((move.grn_gross_weight or 0.0) - (move.grn_tare_weight or 0.0))"/>
                            </t>
                            <t t-else="">-</t>
                        </td>
                    </tr>
                </t>
            </tbody>
        </xpath>
    </template>
</odoo>
